# ------------------------------------------------------------------------------
# Minimal and Safe .htaccess for Sakura Internet
# ------------------------------------------------------------------------------

# Gzip Compression (Safe method)
<IfModule mod_deflate.c>
    SetOutputFilter DEFLATE
    
    # Do not compress images and other binary files
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|woff2?)$ no-gzip dont-vary
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Trailing Slash Redirect
RewriteEngine On
RewriteBase /

# Custom 301 Redirects
RewriteRule ^about\.html$ /about/ [L,R=301]

# Categories to Home
RewriteRule ^category/テクノロジー/?$ / [L,R=301]
RewriteRule ^category/aiツール/?$ / [L,R=301]
RewriteRule ^category/ai戦略/?$ / [L,R=301]
RewriteRule ^category/技術検証/?$ / [L,R=301]
RewriteRule ^category/aiライフスタイル/?$ / [L,R=301]
RewriteRule ^category/開発実録/?$ / [L,R=301]

# Tags to Articles
RewriteRule ^tag/ライティング/?$ /articles/ [L,R=301]
RewriteRule ^tag/ディレクトリ構造/?$ /articles/ [L,R=301]
RewriteRule ^tag/データ移行/?$ /articles/ [L,R=301]
RewriteRule ^tag/タイポグラフィ/?$ /articles/ [L,R=301]
RewriteRule ^tag/ドキュメンタリー/?$ /articles/ [L,R=301]
RewriteRule ^tag/開発ログ/?$ /articles/ [L,R=301]
RewriteRule ^tag/フロントエンド/?$ /articles/ [L,R=301]
RewriteRule ^tag/ブランディング/?$ /articles/ [L,R=301]
RewriteRule ^tag/自動化/?$ /articles/ [L,R=301]
RewriteRule ^tag/効率化テクニック/?$ /articles/ [L,R=301]
RewriteRule ^tag/AI開発/?$ /articles/ [L,R=301]
RewriteRule ^tag/Antigravity/?$ /articles/ [L,R=301]

# Normal Trailing Slash Rule
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)\/$
RewriteRule ^(.*)$ $1/ [L,R=301]
