---
import "../styles/global.css";
import BreadcrumbComponent from "../components/Breadcrumbs.astro";

interface Props {
    title: string;
    description?: string;
    image?: string;
    isArticle?: boolean;
    publishDate?: Date;
    updatedDate?: Date;
    bodyClass?: string;
    faq?: { question: string; answer: string }[];
    howTo?: { name: string; steps: string[] };
    category?: string;
}

const {
    title,
    description = "AIエージェントの導入支援・コンサルティングからエラー解決まで。Antigravity等の自律型AIを実践で使いこなすための知見を記録する、SYNCODE of 技術メディアです。",
    image = "/assets/series-vol1-square.png",
    isArticle = false,
    publishDate,
    updatedDate,
    bodyClass = "",
    faq,
    howTo,
    category,
} = Astro.props;

const { pathname } = Astro.url;
const siteUrl = Astro.site?.toString() || "https://syncode.jp";

// URLの正規化: 明示的な文字列操作で安全に正規化URLを構築
const normalizedPath = pathname.endsWith('/') || pathname.includes('.') ? pathname : `${pathname}/`;
const canonicalURL = new URL(normalizedPath, siteUrl);
const canonicalHref = canonicalURL.href; // 事前に文字列化しておく
const ogImageURL = new URL(image, siteUrl);

// --- Structured Data (Individual Tags for Maximum Compatibility) ---
const siteUrlClean = siteUrl.endsWith('/') ? siteUrl.slice(0, -1) : siteUrl;

// 1. BlogPosting
const blogPostingJson = isArticle ? {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "image": [ogImageURL.toString()],
    "datePublished": publishDate ? publishDate.toISOString() : undefined,
    "dateModified": updatedDate ? updatedDate.toISOString() : (publishDate ? publishDate.toISOString() : undefined),
    "author": {
        "@type": "Organization",
        "name": "SYNCODE",
        "url": siteUrlClean
    },
    "publisher": {
        "@type": "Organization",
        "name": "SYNCODE",
        "logo": {
            "@type": "ImageObject",
            "url": `${siteUrlClean}/assets/series-vol1-square.png`
        }
    },
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonicalHref
    }
} : null;

// 2. BreadcrumbList
const breadcrumbJson = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "TOP",
            "item": `${siteUrlClean}/`
        },
        ...(isArticle ? [{
            "@type": "ListItem",
            "position": 2,
            "name": "ARTICLES",
            "item": `${siteUrlClean}/articles/`
        }] : []),
        ...(isArticle ? [{
            "@type": "ListItem",
            "position": 3,
            "name": title,
            "item": canonicalHref
        }] : [])
    ]
};

// 3. FAQPage
const faqJson = (faq && faq.length > 0) ? {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map(item => ({
        "@type": "Question",
        "name": item.question.trim(),
        "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer.trim()
        }
    }))
} : null;
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="google-site-verification" content="876TBT0pVAHypmR5TeZih86wuOn1IRKM_Rphyfno6WA" />
        <link rel="canonical" href={canonicalHref} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={isArticle ? "article" : "website"} />
        <meta property="og:url" content={canonicalHref} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL.toString()} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:locale" content="ja_JP" />
        <meta property="og:site_name" content="SYNCODE" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@syncode_jp" />
        <meta name="twitter:creator" content="@syncode_jp" />
        <meta name="twitter:url" content={canonicalHref} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL.toString()} />

        <!-- Structured Data -->
        {blogPostingJson && <script type="application/ld+json" set:html={JSON.stringify(blogPostingJson)} />}
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} />
        {faqJson && <script type="application/ld+json" set:html={JSON.stringify(faqJson)} />}

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&family=Noto+Sans+JP:wght@300;400&display=swap"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&family=Noto+Sans+JP:wght@300;400&display=swap"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        />
        <noscript>
            <link
                href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&family=Noto+Sans+JP:wght@300;400&display=swap"
                rel="stylesheet"
            />
        </noscript>
        <script is:inline>
            // 管理者・開発者の除外設定（ノイズ排除の精緻化）
            const GA_MEASUREMENT_ID = 'G-SE8GNFY6EM';
            const ADMIN_MARKER = 'ga_exclude_syncode_sh_7v2'; // シークレットキーに変更
            const SECRET_PARAM = 'auth_gate'; // パラメータ名も推測しにくいものに変更
            const SECRET_VALUE = 'sy-admin-99x'; // パラメータ値

            const disableGA = (persistent = true) => {
                window['ga-disable-' + GA_MEASUREMENT_ID] = true;
                if (persistent) {
                    localStorage.setItem(ADMIN_MARKER, 'true');
                }
                console.log('--- ADMIN MODE: GA4 Tracking Disabled ---');
            };

            const enableGA = () => {
                window['ga-disable-' + GA_MEASUREMENT_ID] = false;
                localStorage.removeItem(ADMIN_MARKER);
                console.log('--- USER MODE: GA4 Tracking Enabled ---');
                window.location.reload();
            };

            const params = new URLSearchParams(window.location.search);
            // シークレットな組み合わせの場合のみ除外を発動
            if (params.get(SECRET_PARAM) === SECRET_VALUE || localStorage.getItem(ADMIN_MARKER) === 'true') {
                disableGA();
            } else if (params.get('admin') === 'off') {
                enableGA();
            }
        </script>
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-SE8GNFY6EM"></script>
        <script is:inline set:html={`
            window.dataLayer = window.dataLayer || [];
            function gtag(){window.dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-SE8GNFY6EM', {
                'anonymize_ip': true,
                'cookie_flags': 'SameSite=None;Secure',
                'page_location': '${canonicalHref}',
                'send_page_view': true
            });

            // ユーザー行動の自動計測
            document.addEventListener('DOMContentLoaded', () => {
                if (window['ga-disable-G-SE8GNFY6EM']) return;

                // 1. クリック計測（アフィリエイト・内部重要導線・CTA）
                document.addEventListener('click', (e) => {
                    const target = e.target.closest('a');
                    if (!target) return;

                    const href = target.getAttribute('href');
                    const isExternal = target.getAttribute('target') === '_blank' || (href && href.startsWith('http') && !href.includes(window.location.hostname));
                    const linkText = target.innerText?.trim().slice(0, 50) || '';

                    // CTA（バナー類）の計測
                    const ctaBanner = target.closest('.cta-inline, .cta-plate, .cta-tools, .cta-works, .cta-next-banner');
                    if (ctaBanner) {
                        const ctaTag = ctaBanner.querySelector('.cta-inline__tag, .cta-label')?.innerText || 'CTA';
                        gtag('event', 'cta_interaction', {
                            cta_label: ctaTag + ': ' + linkText,
                            cta_destination: href,
                            page_location: window.location.href
                        });
                        return; // CTAとして計測した場合は重複を避けるためここで終了
                    }

                    // アフィリエイト/外部リンク計測
                    if (isExternal && href) {
                        gtag('event', 'affiliate_click', {
                            link_url: href,
                            link_text: linkText,
                            page_location: window.location.href
                        });
                    }

                    // トラブルシューティング診断カード計測
                    if (target.classList.contains('troubleshoot-card')) {
                        const symptom = target.querySelector('.symptom-label')?.innerText || 'unknown';
                        gtag('event', 'diagnosis_click', {
                            symptom_name: symptom,
                            target_url: href
                        });
                    }

                    // ハブ/ロードマップ操作計測
                    if (target.classList.contains('nav-card') || target.classList.contains('action-card')) {
                        gtag('event', 'hub_navigation', {
                            nav_label: target.querySelector('.nav-label, .card-label')?.innerText || 'unknown',
                            nav_title: target.querySelector('.nav-title, .card-name')?.innerText || linkText
                        });
                    }
                });

                // 2. カテゴリフィルター計測
                document.addEventListener('click', (e) => {
                    const btn = e.target.closest('.filter-item');
                    if (!btn) return;
                    
                    const filterName = btn.getAttribute('data-filter');
                    gtag('event', 'discovery_filter', {
                        filter_name: filterName
                    });
                });

                // 3. 読了率（スクロール深度）計測
                let scrollMarkers = [25, 50, 75, 90];
                let sentMarkers = new Set();
                
                window.addEventListener('scroll', () => {
                    const h = document.documentElement, 
                          b = document.body,
                          st = 'scrollTop',
                          sh = 'scrollHeight';
                    const percent = (h[st]||b[st]) / ((h[sh]||b[sh]) - h.clientHeight) * 100;
                    
                    scrollMarkers.forEach(m => {
                        if (percent >= m && !sentMarkers.has(m)) {
                            sentMarkers.add(m);
                            gtag('event', 'scroll_depth', {
                                depth_percent: m,
                                page_location: window.location.href
                            });
                        }
                    });
                }, { passive: true });
            });
        `}>
        </script>
        <!-- Microsoft Clarity -->
        <script type="text/javascript" is:inline>
            (function(c,l,a,r,i,t,y){
                c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
            })(window, document, "clarity", "script", "wfzy04mrpp");
        </script>
    </head>
    <body id="top" class={bodyClass}>
        <header class="site-header">
            <div class="header-inner">
                <div class="logo"><a href="/">SYNCODE</a></div>
                <nav class="main-nav">
                    <ul>
                        <li>
                            <a href="/" class={pathname === "/" ? "active" : ""}
                                >TOP</a
                            >
                        </li>
                        <li>
                            <a
                                href="/antigravity/hub/"
                                class={pathname.startsWith("/antigravity")
                                    ? "active"
                                    : ""}>HUB</a
                            >
                        </li>
                        <li>
                            <a
                                href="/about/"
                                class={pathname.startsWith("/about")
                                    ? "active"
                                    : ""}>ABOUT</a
                            >
                        </li>
                        <li>
                            <a
                                href="/service/"
                                class={pathname.startsWith("/service")
                                    ? "active"
                                    : ""}>SERVICE</a
                            >
                        </li>
                        <li>
                            <a
                                href="/works/"
                                class={pathname.startsWith("/works")
                                    ? "active"
                                    : ""}>WORK</a
                            >
                        </li>
                        <li>
                            <a
                                href="/tools/"
                                class={pathname.startsWith("/tools")
                                    ? "active"
                                    : ""}>TOOLS</a
                            >
                        </li>
                    </ul>
                </nav>
            </div>
        </header>

        <!-- スクロール固定時のレイアウトずれを防ぐスペーサー -->
        <div id="header-spacer" style="height: 0;"></div>

        <main class={`site-main ${isArticle ? "article-page" : ""}`}>
            {pathname !== "/" && (
                <div class="breadcrumb-container">
                    <BreadcrumbComponent currentTitle={title} isArticle={isArticle} />
                </div>
            )}
            <slot />
        </main>

        <footer class="site-footer">
            <div class="footer-inner">
                <div class="footer-logo">SYNCODE</div>
                <ul class="footer-links">
                    <li><a href="https://x.com/syncode_jp" target="_blank" rel="noopener noreferrer">X (Twitter)</a></li>

                </ul>
                <p class="copyright">&copy; 2026 SYNCODE.</p>
                <div id="ga-status-indicator" style="display:none; font-size: 10px; color: #ccc; margin-top: 10px; letter-spacing: 0.1em;">
                    [ STATUS: <span style="color: #ffcc00;">ADMIN MODE / TRACKING DISABLED</span> ]
                    <a href="?admin=off" style="color: #999; margin-left: 10px; text-decoration: underline;">Switch to User Mode</a>
                </div>
                <p class="footer-pr-disclosure">
                    本サイトの一部のリンクはアフィリエイト広告（プロモーション）を含んでいます。
                    これらのリンクを経由して商品・サービスを購入された場合、サイト運営者に報酬が発生することがあります。
                    掲載内容は実際の使用経験に基づいており、広告報酬による評価への影響はありません。
                </p>
            </div>
        </footer>

        <!-- Back to Top Button -->
        <button
            id="back-to-top"
            class="back-to-top"
            aria-label="ページトップへ戻る">TOP</button
        >

        <script>
            const header = document.querySelector('.site-header') as HTMLElement | null;
            const spacer = document.getElementById('header-spacer');
            const backToTopBtn = document.getElementById('back-to-top');

            // --- GA Status Indicator (Admin only) ---
            const statusIndicator = document.getElementById('ga-status-indicator');
            if (statusIndicator && (localStorage.getItem('ga_exclude_syncode_sh_7v2') === 'true' || window.location.search.includes('auth_gate=sy-admin-99x'))) {
                statusIndicator.style.display = 'block';
                statusIndicator.style.border = '1px solid #ffcc00';
                statusIndicator.style.padding = '5px';
                statusIndicator.style.display = 'inline-block';
            }

            // --- Sticky header ---
            const SCROLL_THRESHOLD = 80;

            function updateHeader() {
                if (!header || !spacer) return;
                if (window.scrollY > SCROLL_THRESHOLD) {
                    header.classList.add('is-scrolled');
                    spacer.style.height = header.offsetHeight + 'px';
                } else {
                    header.classList.remove('is-scrolled');
                    spacer.style.height = '0px';
                }
            }

            window.addEventListener('scroll', updateHeader, { passive: true });
            updateHeader(); // 初期状態にも適用

            // --- Back to Top ---
            if (backToTopBtn) {
                backToTopBtn.addEventListener('click', () => {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
                window.addEventListener('scroll', () => {
                    if (window.scrollY > 300) {
                        backToTopBtn.classList.add('visible');
                    } else {
                        backToTopBtn.classList.remove('visible');
                    }
                }, { passive: true });
            }

            // --- GA4 外部リンク クリック計測 ---
            // ※ headセクションのグローバルリスナーに統合・移行したため、ここでの処理は削除しました。
        </script>

        <style is:global>
            /* ===== ヘッダー：通常状態 ===== */
            .site-header {
                padding: 60px 0 40px !important;
                text-align: center !important;
                background: var(--color-bg) !important;
                transition: box-shadow 0.3s ease, background 0.3s ease;
                position: relative;
                z-index: 100;
                display: block !important; /* flexによる横並びを阻止 */
            }

            .site-header .header-inner {
                display: flex !important;
                flex-direction: column !important;
                align-items: center !important;
                gap: 0 !important;
                max-width: 1100px;
                margin: 0 auto;
                padding: 0 5%;
            }

            .site-header .logo {
                font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
                font-size: 1.4rem !important;
                font-weight: bold !important;
                letter-spacing: 0.12em !important;
                margin-bottom: 30px !important;
                transition: all 0.3s ease;
            }

            /* ===== ヘッダー：スクロール後（固定状態） ===== */
            .site-header.is-scrolled {
                position: fixed !important;
                top: 0 !important;
                left: 0 !important;
                right: 0 !important;
                padding: 0 !important;
                background: var(--color-bg) !important;
                opacity: 0.98;
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
                border-bottom: 1px solid var(--color-border);
                box-shadow: 0 2px 20px rgba(0, 0, 0, 0.04);
            }

            .site-header.is-scrolled .header-inner {
                flex-direction: row !important;
                justify-content: space-between !important;
                align-items: center !important;
                height: 60px !important;
                gap: 0 !important;
            }

            .site-header.is-scrolled .logo {
                font-size: 1.1rem !important;
                margin-bottom: 0 !important;
                flex-shrink: 0;
            }

            /* ===== ナビゲーション共通 ===== */
            .main-nav ul {
                display: flex !important;
                justify-content: center !important;
                align-items: center !important;
                gap: 12px !important;
                padding: 0;
                margin: 0;
                list-style: none;
            }

            .main-nav a {
                font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
                font-size: 0.75rem !important;
                text-transform: uppercase;
                letter-spacing: 0.15em !important;
                color: var(--color-text-light) !important;
                display: inline-block;
                padding: 6px 14px;
                border-radius: 4px;
                background-color: transparent;
                transition: all 0.3s ease;
                text-decoration: none;
            }

            .main-nav a:hover {
                color: var(--color-text) !important;
                background-color: var(--color-bg-alt);
            }

            .main-nav a.active {
                background-color: var(--color-bg-alt);
                color: var(--color-text) !important;
                font-weight: bold;
            }

            /* スクロール後はナビの文字をやや小さく */
            .site-header.is-scrolled .main-nav a {
                padding: 6px 10px;
                font-size: 0.7rem !important;
            }

            /* スマホ（iPhone 13 mini等）でのナビゲーションはみ出し対策 */
            @media (max-width: 480px) {
                .site-header {
                    padding: 40px 0 30px !important;
                }
                .site-header .logo {
                    font-size: 1.2rem !important;
                    margin-bottom: 20px !important;
                }
                .main-nav ul {
                    gap: 4px !important; /* 間隔を詰める */
                }
                .main-nav a {
                    font-size: 0.65rem !important;
                    padding: 6px 4px; /* パディングを最小化 */
                    letter-spacing: 0.02em !important;
                }
                .site-header.is-scrolled .header-inner {
                    padding: 0 10px !important;
                }
                .site-header.is-scrolled .logo {
                    font-size: 0.9rem !important;
                }
                .site-header.is-scrolled .main-nav a {
                    font-size: 0.6rem !important;
                    padding: 4px 4px;
                    letter-spacing: 0em !important;
                }
            }
        </style>
    </body>
</html>
