---
interface Props {
  title: string;
  excerpt?: string;
  image: string;
  link: string;
  order?: number;
}

const { title, excerpt, image, link, order } = Astro.props;
---

<div class="cta-next-banner">
  <a href={link} class="banner-link">
    <div class="banner-content">
      <div class="banner-header">
        <span class="next-label">NEXT EPISODE</span>
        {order && <span class="order-label">Vol.{String(order).padStart(2, '0')}</span>}
      </div>
      <h3 class="banner-title">{title}</h3>
      {excerpt && <p class="banner-excerpt">{excerpt}</p>}
      <div class="banner-action">
        <span class="action-text">物語の続きを読み進める</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>
    </div>
    <div class="banner-visual">
       <img src={image} alt="" aria-hidden="true" />
       <div class="visual-overlay"></div>
    </div>
  </a>
</div>

<style>
  .cta-next-banner {
    margin: 100px 0;
    width: 100%;
    overflow: hidden;
    border-radius: 4px; /* ソリッドな角へ */
    background: #0c0c0c;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .cta-next-banner:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .banner-link {
    display: flex;
    text-decoration: none;
    color: #fff;
    min-height: 320px;
    position: relative;
  }

  .banner-content {
    flex: 1.2;
    padding: 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 2;
    position: relative;
  }

  .banner-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .next-label {
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.4em;
    color: #888;
    text-transform: uppercase;
  }

  .order-label {
    font-size: 0.65rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.1em;
  }

  .banner-title {
    font-size: 1.6rem;
    font-weight: 300;
    margin: 0 0 20px 0;
    line-height: 1.4;
    letter-spacing: 0.1em;
  }

  .banner-excerpt {
    font-size: 0.9rem; /* 10.8pt */
    color: #666;
    margin: 0 0 32px 0;
    line-height: 2;
    letter-spacing: 0.08em; /* Tracking 80 */
    max-width: 90%;
  }

  .banner-action {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.75rem;
    font-weight: 400;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: gap 0.3s ease;
  }

  .banner-link:hover .banner-action {
    gap: 28px;
  }

  .banner-action::after {
    content: "";
    width: 30px;
    height: 1px;
    background: #fff;
    transition: width 0.3s ease;
  }

  .banner-link:hover .banner-action::after {
    width: 60px;
  }

  .banner-visual {
    flex: 0.7;
    position: relative;
    overflow: hidden;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid rgba(255, 255, 255, 0.05);
  }

  .banner-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    transition: transform 1.2s cubic-bezier(0.2, 1, 0.3, 1), opacity 0.4s ease;
  }

  .banner-link:hover .banner-visual img {
    transform: scale(1.05);
    opacity: 0.9;
  }

  .visual-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, #0c0c0c 0%, transparent 100%);
  }

  @media (max-width: 900px) {
    .banner-link {
      flex-direction: column;
    }
    .banner-content {
      order: 2;
      padding: 40px;
    }
    .banner-visual {
      order: 1;
      height: 200px;
      border-left: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .visual-overlay {
      background: linear-gradient(to top, #0c0c0c 0%, transparent 100%);
    }
    .banner-title {
      font-size: 1.25rem;
    }
  }
</style>
