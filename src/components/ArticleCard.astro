---
import Category from "./Category.astro";
import Tag from "./Tag.astro";

interface Props {
  article: any;
  variant?: 'premium' | 'standard';
  step?: number;
  topLabel?: string;
}

const { article, variant = 'standard', step, topLabel } = Astro.props;
const isSalon = article.data.category === 'INSIGHT';

// カテゴリに応じたアクセントカラー
const getCategoryColor = (category: string) => {
  if (category === 'INSIGHT') return '#FACC15'; // Salon Gold
  switch (category) {
    case 'AI戦略': return '#0099ff';
    case 'AIツール': return '#00d1b2';
    case '技術検証': return '#ffdd57';
    case 'テクノロジー': return '#8e44ad';
    case 'マーケティング': return '#ff3860';
    case '開発実録': return '#6c5ce7';
    default: return '#333';
  }
};

const categoryColor = getCategoryColor(article.data.category || '');
---

<article 
  class={`article-card ${variant} ${isSalon ? 'is-salon' : ''}`}
  data-category={article.data.category || ''}
  data-tags={article.data.tags?.join(',') || ''}
>
  <div class="card-link-wrapper">
    <a href={`/articles/${article.id}/`} class="thumbnail-link">
      <div class="thumbnail-wrapper"><img
          src={article.data.image}
          alt={`${article.data.title}のサムネイル`}
          loading="lazy"
        />
        
        {isSalon && (
          <div class="salon-seal">
            <span class="seal-text">THOUGHT PARTNERSHIP</span>
          </div>
        )}

        {variant === 'premium' && step && (
          <div class="step-badge">
            <span class="step-num">{String(step).padStart(2, '0')}</span>
          </div>
        )}
      </div>
    </a>

    <div class="card-content">
      {isSalon ? (
        <div class="salon-meta">
          <div class="salon-label">
            <span class="dot"></span>
            INSIGHT SALON
          </div>
          <a href={`/articles/${article.id}/`} class="title-link">
            <h3 class="card-title salon-title">{article.data.title}</h3>
          </a>
          <time class="post-date salon-date">
            {article.data.date
              .toLocaleDateString("ja-JP", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
              })
              .replace(/\//g, ".")}
          </time>
        </div>
      ) : variant === 'premium' ? (
        <div class="premium-meta">
          <div class="story-chronicle">PROJECT STORY CHRONICLES</div>
          <a href={`/articles/${article.id}/`} class="title-link">
            <h3 class="card-title">{article.data.title}</h3>
          </a>
          <p class="card-excerpt">{article.data.excerpt}</p>
        </div>
      ) : (
        <div class="standard-meta">
          {topLabel && <div class="top-label">{topLabel}</div>}
          <div class="category-wrapper">
            <span class="category-name">{article.data.category}</span>
            <div class="category-line" style={`background-color: ${categoryColor};`}></div>
          </div>
          <time class="post-date">
            {article.data.date
              .toLocaleDateString("ja-JP", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
              })
              .replace(/\//g, ".")}
          </time>
          <a href={`/articles/${article.id}/`} class="title-link">
            <h3 class="card-title">{article.data.title}</h3>
          </a>
          <p class="card-excerpt">{article.data.excerpt}</p>
          
          {article.data.tags && article.data.tags.length > 0 && (
            <div class="tag-list">
              {article.data.tags.slice(0, 3).map((tag: string) => <Tag name={tag} />)}
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    min-width: 0; /* Important for grid consistency */
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .thumbnail-link {
    display: block;
    text-decoration: none;
    margin: 0 !important;
    padding: 0 !important;
  }

  .thumbnail-wrapper {
    position: relative !important;
    width: 100% !important;
    aspect-ratio: 1 / 1 !important;
    overflow: hidden !important;
    margin: 0 0 24px 0 !important;
    padding: 0 !important;
    background: #f0f0f0 !important;
    border: 1px solid #f0f0f0 !important;
  }

  .title-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .premium .thumbnail-wrapper {
    background: #111;
    border-color: #222;
  }

  .thumbnail-wrapper img {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    margin: 0 !important;
    border-radius: 0 !important;
    object-fit: cover !important;
    object-position: center !important;
    display: block !important;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1) !important;
  }

  .article-card:hover .thumbnail-wrapper img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 0;
    margin: 0;
  }

  .card-title {
    margin: 0 0 12px 0;
    line-height: 1.5;
    height: 3em; 
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 1.1rem;
    font-weight: 700;
    overflow-wrap: anywhere; /* Prevent long words from breaking layout */
    word-break: normal;
  }

  /* Premium (Documentary) styles */
  .premium .story-chronicle {
    font-size: 0.65rem;
    font-weight: 700;
    color: #1a88ff;
    letter-spacing: 0.15em;
    margin-bottom: 8px;
  }

  .premium .card-title {
    color: #fff;
    font-size: 1.05rem;
  }

  .premium .card-excerpt {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
    margin-top: 12px;
  }

  /* Standard styles */
  .standard-meta {
    text-align: left;
  }

  .category-wrapper {
    display: inline-block;
    margin-bottom: 12px;
  }

  .category-name {
    font-size: 0.7rem;
    font-weight: 900;
    color: #333;
    letter-spacing: 0.1em;
  }

  /* 3. カラーラインの伸張エフェクト */
  .category-line {
    height: 2px;
    margin-top: 4px;
    width: 100%;
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    color: #999;
    margin-bottom: 10px;
    letter-spacing: 0.05em;
  }

  .top-label {
    font-size: 0.65rem;
    font-weight: 900;
    color: #1a88ff;
    letter-spacing: 0.2em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .standard .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #2c2c2c;
  }

  .standard .card-excerpt {
    font-size: 0.9rem;
    color: #777;
    margin-top: 12px;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 15px;
  }

  /* UI Decorations */
  .step-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #fff;
    color: #000;
    padding: 6px 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 10;
  }

  .step-num {
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.1em;
  }

  /* Hover states */
  .standard.article-card:hover .card-title {
    color: #000 !important;
  }

  .premium.article-card:hover .card-title {
    color: #fff !important;
  }

  /* INSIGHT (SALON) Premium Card Styles */
  .is-salon {
    background: #05080c !important;
    padding: 16px;
    border-radius: 4px;
    border: 1px solid rgba(250, 204, 21, 0.05);
  }

  .is-salon:hover {
    border-color: rgba(250, 204, 21, 0.2);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .is-salon .thumbnail-wrapper {
    margin-bottom: 20px;
    border: none;
    background: #000;
  }

  .salon-seal {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 10;
    background: rgba(250, 204, 21, 0.9);
    padding: 4px 8px;
    border-radius: 2px;
    backdrop-filter: blur(4px);
  }

  .seal-text {
    font-size: 0.5rem;
    font-weight: 900;
    color: #000;
    letter-spacing: 0.15em;
    white-space: nowrap;
    display: block;
  }

  .salon-meta {
    padding: 0 4px 12px;
  }

  .salon-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.65rem;
    font-weight: 800;
    color: #FACC15;
    letter-spacing: 0.2em;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .salon-label .dot {
    width: 6px;
    height: 6px;
    background: #FACC15;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 10px #FACC15;
    animation: salon-pulse 3s infinite ease-in-out;
  }

  @keyframes salon-pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  .salon-title {
    color: #fff !important;
    font-size: 1.1rem !important;
    font-weight: 800 !important;
    line-height: 1.6 !important;
    margin-bottom: 24px !important;
    letter-spacing: 0.02em !important;
  }

  .salon-date {
    color: rgba(255, 255, 255, 0.3) !important;
    font-size: 0.7rem !important;
    font-weight: 500 !important;
  }

</style>
