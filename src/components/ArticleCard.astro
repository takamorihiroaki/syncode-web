---
import Category from "./Category.astro";
import Tag from "./Tag.astro";

interface Props {
  article: any;
  variant?: 'premium' | 'standard';
  step?: number;
  topLabel?: string;
}

const { article, variant = 'standard', step, topLabel } = Astro.props;

// カテゴリに応じたアクセントカラー
const getCategoryColor = (category: string) => {
  switch (category) {
    case 'AI戦略': return '#0099ff';
    case 'AIツール': return '#00d1b2';
    case '技術検証': return '#ffdd57';
    case 'テクノロジー': return '#8e44ad';
    case 'マーケティング': return '#ff3860';
    case '開発実録': return '#6c5ce7';
    default: return '#333';
  }
};

const categoryColor = getCategoryColor(article.data.category || '');
---

<article 
  class={`article-card ${variant}`}
  data-category={article.data.category || ''}
  data-tags={article.data.tags?.join(',') || ''}
>
  <div class="thumbnail-wrapper">
    <a href={`/articles/${article.id}/`} class="image-link" aria-label={`${article.data.title}を読む`}>
      <img
        src={article.data.image}
        alt={`${article.data.title}のサムネイル`}
        loading="lazy"
      />
    </a>
    
    {variant === 'premium' && step && (
      <div class="step-badge">
        <span class="step-num">{String(step).padStart(2, '0')}</span>
      </div>
    )}
  </div>

  <div class="card-content">
    {variant === 'premium' ? (
      <div class="premium-meta">
        <div class="story-chronicle">PROJECT STORY CHRONICLES</div>
        <h3 class="card-title">
          <a href={`/articles/${article.id}/`}>{article.data.title}</a>
        </h3>
        <p class="card-excerpt">{article.data.excerpt}</p>
      </div>
    ) : (
      <div class="standard-meta">
        {topLabel && <div class="top-label">{topLabel}</div>}
        <div class="category-wrapper">
          <span class="category-name">{article.data.category}</span>
          <div class="category-line" style={`background-color: ${categoryColor};`}></div>
        </div>
        <time class="post-date">
          {article.data.date
            .toLocaleDateString("ja-JP", {
              year: "numeric",
              month: "2-digit",
              day: "2-digit",
            })
            .replace(/\//g, ".")}
        </time>
        <h3 class="card-title">
          <a href={`/articles/${article.id}/`}>{article.data.title}</a>
        </h3>
        <p class="card-excerpt">{article.data.excerpt}</p>
        
        {article.data.tags && article.data.tags.length > 0 && (
          <div class="tag-list">
            {article.data.tags.slice(0, 3).map((tag: string) => <Tag name={tag} />)}
          </div>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .image-link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
  }

  .thumbnail-wrapper {
    position: relative;
    aspect-ratio: 1 / 1 !important;
    overflow: hidden;
    margin-bottom: 24px;
    background: #f0f0f0;
    border: 1px solid #f0f0f0;
  }

  .premium .thumbnail-wrapper {
    background: #111;
    border-color: #222;
  }

  .thumbnail-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .article-card:hover .thumbnail-wrapper img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 0;
    margin: 0;
  }

  .card-title {
    margin: 0 0 12px 0;
    line-height: 1.5;
    height: 3em; 
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .card-title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.3s ease;
  }

  .article-card:hover .card-title a {
    color: #000;
  }

  /* Premium (Documentary) styles */
  .premium .story-chronicle {
    font-size: 0.65rem;
    font-weight: 700;
    color: #1a88ff;
    letter-spacing: 0.15em;
    margin-bottom: 8px;
  }

  .premium .card-title {
    color: #fff;
    font-size: 1.05rem;
  }

  .premium .card-excerpt {
    color: rgba(255, 255, 255, 0.85); /* 視認性向上のために不透明度アップ */
    font-size: 0.85rem;
    margin-top: 12px;
  }

  /* Standard styles */
  .standard-meta {
    text-align: left;
  }

  .category-wrapper {
    display: inline-block;
    margin-bottom: 12px;
  }

  .category-name {
    font-size: 0.7rem;
    font-weight: 900;
    color: #333;
    letter-spacing: 0.1em;
  }

  .category-line {
    height: 2px;
    margin-top: 4px;
    width: 100%;
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    color: #444; /* コントラスト強化: #999から修正 */
    margin-bottom: 10px;
    letter-spacing: 0.05em;
  }

  .top-label {
    font-size: 0.65rem;
    font-weight: 900;
    color: #1a88ff;
    letter-spacing: 0.2em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .standard .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #2c2c2c;
  }

  .standard .card-excerpt {
    font-size: 0.9rem;
    color: #222; /* コントラスト強化: #777から修正 */
    margin-top: 12px;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 15px;
  }

  /* UI Decorations */
  .step-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #fff;
    color: #000;
    padding: 6px 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 10;
  }

  .step-num {
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.1em;
  }

  /* Hover states */
  .standard.article-card:hover .card-title {
    color: #000 !important;
  }

  .premium.article-card:hover .card-title {
    color: #fff !important;
  }

</style>
