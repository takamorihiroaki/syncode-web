---
/*
  ReadingProgressBar.astro
  記事の読了状況を画面上部にプログレスバーとして表示するコンポーネント
*/
---

<div id="reading-progress-bar" class="progress-bar-container">
  <div class="progress-bar-fill"></div>
</div>

<script>
  function updateProgressBar() {
    const progressBar = document.querySelector('.progress-bar-fill') as HTMLElement;
    if (!progressBar) return;

    // 記事コンテンツの要素を取得（スクロール計算の基準）
    const article = document.querySelector('.article-content');
    if (!article) return;

    const winScroll = window.scrollY;
    // 記事の開始位置と高さを取得
    const articleRect = article.getBoundingClientRect();
    const articleTop = articleRect.top + winScroll;
    const articleHeight = articleRect.height;
    
    // 現在のウィンドウの高さ
    const winHeight = window.innerHeight;
    
    // 進捗計算（記事の冒頭から末尾まで）
    let scrolled = ((winScroll - articleTop + winHeight) / articleHeight) * 100;
    
    // 範囲を 0 - 100 に制限
    scrolled = Math.max(0, Math.min(100, scrolled));
    
    progressBar.style.width = scrolled + "%";
  }

  // スクロール時とリサイズ時に実行
  window.addEventListener('scroll', updateProgressBar);
  window.addEventListener('resize', updateProgressBar);
  
  // 初期表示時にも実行
  document.addEventListener('astro:page-load', updateProgressBar);
  updateProgressBar();
</script>

<style>
  .progress-bar-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: transparent;
    z-index: 9999;
    pointer-events: none; /* 下の要素のクリックを邪魔しない */
  }

  .progress-bar-fill {
    height: 100%;
    width: 0%;
    background: rgba(0, 153, 255, 0.5); /* 半透明のアクセントブルー */
    background: linear-gradient(to right, rgba(0, 153, 255, 0.4), rgba(0, 153, 255, 0.7));
    box-shadow: 0 0 8px rgba(0, 153, 255, 0.2);
    transition: width 0.15s ease-out;
  }

  /* ヘッダーが固定されている場合、そのすぐ下に配置するか最上部にするか */
  /* 今回は最上部に配置しています */
</style>
