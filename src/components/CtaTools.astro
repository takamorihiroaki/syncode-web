---
interface Props {
    title?: string;
    description?: string;
}

const { 
    title = "使用しているAI・開発ツール一覧", 
    description = "SYNCODEブログの構築や、日々の開発・執筆に活用しているおすすめの厳選ツールを紹介しています。" 
} = Astro.props;
---

<div class="cta-tools-wrapper">
    <a href="/tools/" class="cta-tools-link">
        <div class="cta-content">
            <span class="cta-badge">Recommend</span>
            <h3 class="cta-title"><span>{title}</span></h3>
            <p class="cta-desc">{description}</p>
        </div>
    </a>
</div>

<style>
    .cta-tools-wrapper {
        margin: 60px 0 40px;
        width: 100%;
    }

    .cta-tools-link {
        display: block;
        padding: 40px;
        background: #fafafa;
        border: 1px solid var(--color-border, #eee);
        border-radius: 8px;
        text-decoration: none;
        color: var(--color-text, #333);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
    }
    
    .cta-tools-link:hover {
        background: #fdfdfd;
        border-color: #000;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        transform: translateY(-2px);
    }

    .cta-badge {
        display: inline-block;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 20px;
        transition: color 0.3s ease;
    }

    .cta-tools-link:hover .cta-badge {
        color: #000;
    }

    .cta-title {
        font-size: 1.35rem;
        font-weight: 800;
        margin: 0 0 12px 0;
        line-height: 1.4;
    }

    /* 100%ベストの下線アニメーション */
    .cta-title span {
        display: inline;
        background-image: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.15));
        background-position: 0 100%;
        background-repeat: no-repeat;
        background-size: 0 1px;
        transition: background-size 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        padding-bottom: 4px;
        box-decoration-break: clone;
        -webkit-box-decoration-break: clone;
    }

    .cta-tools-link:hover .cta-title span {
        background-size: 100% 1px;
    }

    .cta-desc {
        font-size: 0.95rem;
        color: #666;
        margin: 0;
        line-height: 1.7;
        max-width: 600px;
    }

    @media (max-width: 640px) {
        .cta-tools-link {
            padding: 30px;
        }
        .cta-title {
            font-size: 1.2rem;
        }
    }
</style>
