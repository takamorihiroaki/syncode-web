---
/* 
  RoadmapHub.astro
  Antigravityの学習ステップを視覚化するロードマップコンポーネント
*/

interface Props {
  activePhase?: string; // "01", "02", "03", "04"
  showHeader?: boolean;
}

const { activePhase, showHeader = true } = Astro.props;

interface Phase {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  articles: {
    title: string;
    url: string;
    tag?: string;
  }[];
  icon: string;
}

const phases: Phase[] = [
  {
    id: "01",
    title: "IGNITION",
    subtitle: "導入・環境構築",
    description: "Antigravityを正しくセットアップし、AIエージェントが自律的に動くための「土壌」を整えます。",
    icon: "🚀",
    articles: [
      { title: "Antigravity スタートガイド", url: "/articles/antigravity-start/" },
      { title: "初期設定とカスタマイズの秘訣", url: "/articles/antigravity-initial-setup-guide/" },
      { title: "MCP(Model Context Protocol)導入", url: "/articles/mcp-basics-guide/" }
    ]
  },
  {
    id: "02",
    title: "ORBIT",
    subtitle: "基本操作・習熟",
    description: "自律参照の仕組みを理解し、ファイルや画像を用いた高度な指示出しをマスターします。",
    icon: "📡",
    articles: [
      { title: "ファイル・画像添付の完全攻略", url: "/articles/antigravity-file-attachment-guide/", tag: "MUST" },
      { title: "ブラウザ制御の自律運用法", url: "/articles/antigravity-browser-control-guide/" },
      { title: "Cursor連携ワークフロー", url: "/articles/cursor-antigravity-workflow/" }
    ]
  },
  {
    id: "03",
    title: "RECOVERY",
    subtitle: "問題解決・最適化",
    description: "挙動の不安定さやパフォーマンスの低下を克服し、信頼性の高いエージェントへと磨き上げます。",
    icon: "🛠️",
    articles: [
      { title: "「動かない」時のチェックリスト", url: "/articles/antigravity-not-working-fix/" },
      { title: "速度向上：プロンプトキャッシュ術", url: "/articles/antigravity-speed-optimization-prompt-cache/", tag: "PRO" },
      { title: "ディレクトリ構成の極意", url: "/articles/antigravity-file-ops-mastery/" }
    ]
  },
  {
    id: "04",
    title: "BEYOND",
    subtitle: "高度な自動化・未来",
    description: "AIを単なるツールではなく「自律した部下」として扱い、人間の創造性を最大化する領域へ。",
    icon: "🌌",
    articles: [
      { title: "自作MCPサーバーで拡張する", url: "/articles/mcp-server-custom-guide/" },
      { title: "Vibe Coding：直感的開発の実践", url: "/articles/vibe-coding-practice-report/" },
      { title: "AIフルスタック開発の全貌", url: "/articles/ai-fullstack-devops/" }
    ]
  }
];
---

<section class="roadmap-hub">
  {showHeader && (
    <div class="roadmap-header">
      <div class="roadmap-badge">SYSTEMATIC LEARNING PATH</div>
      <h2 class="roadmap-main-title">ANTIGRAVITY<br/><span class="gradient-text">COMPLETE HUB</span></h2>
      <p class="roadmap-intro">
        点在する技術情報を「一本の道」に。導入からプロレベルの自動化まで、<br/>
        Antigravityを完全に使いこなすための体系的ガイドラインです。
      </p>
    </div>
  )}

  <div class="roadmap-path">
    {phases.map((phase) => (
      <div class={`phase-card ${phase.id === activePhase ? 'is-active' : ''}`}>
        <div class="phase-visual">
          <div class="phase-number">{phase.id}</div>
          <div class="phase-icon-orbit">
             <span class="phase-icon">{phase.icon}</span>
          </div>
          <div class="phase-line"></div>
        </div>
        
        <div class="phase-content">
          <div class="phase-meta">
            <span class="phase-title">{phase.title}</span>
            <h3 class="phase-subtitle">{phase.subtitle}</h3>
          </div>
          <p class="phase-description">{phase.description}</p>
          
          <ul class="phase-article-list">
            {phase.articles.map((art) => (
              <li>
                <a href={art.url}>
                  <span class="art-title">{art.title}</span>
                  {art.tag && <span class={`art-tag ${art.tag.toLowerCase()}`}>{art.tag}</span>}
                  <span class="art-arrow">→</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .roadmap-hub {
    padding: 100px 0;
    max-width: 1000px;
    margin: 0 auto;
  }

  .roadmap-header {
    text-align: center;
    margin-bottom: 80px;
    padding: 0 5%;
  }

  .roadmap-badge {
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.4em;
    color: #0099ff;
    background: transparent;
    margin-bottom: 24px;
    display: inline-block;
    padding: 6px 16px;
    border: 1px solid rgba(0, 153, 255, 0.2);
    border-radius: 4px;
  }

  .roadmap-main-title {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 30px;
    letter-spacing: -0.02em;
    color: #1a1a1a;
  }

  .gradient-text {
    background: linear-gradient(135deg, #000 0%, #666 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .roadmap-intro {
    font-size: 1rem;
    color: #666;
    line-height: 1.8;
  }

  /* Roadmap Path */
  .roadmap-path {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0 5%;
  }

  .phase-card {
    display: flex;
    gap: 60px;
    position: relative;
  }

  .phase-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 60px;
    flex-shrink: 0;
  }

  .phase-number {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 800;
    color: #ccc;
    margin-bottom: 15px;
  }

  .phase-icon-orbit {
    width: 50px;
    height: 50px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.4s ease;
    box-shadow: 0 4px 10px rgba(0,0,0,0.03);
  }

  .phase-card:hover .phase-icon-orbit {
    border-color: var(--color-text);
    transform: scale(1.1);
    box-shadow: 0 10px 20px rgba(0,0,0,0.08);
  }

  .phase-card.is-active .phase-icon-orbit {
    border-color: var(--color-primary);
    background: var(--color-bg-alt);
    box-shadow: 0 0 15px rgba(0, 153, 255, 0.2);
    transform: scale(1.1);
  }

  .phase-card.is-active .phase-subtitle {
    color: var(--color-primary);
  }

  .phase-card.is-active::before {
    content: "YOU ARE HERE";
    position: absolute;
    top: 0;
    right: 0;
    font-size: 0.6rem;
    font-weight: 900;
    color: var(--color-primary);
    letter-spacing: 0.2em;
    padding: 4px 10px;
    background: var(--color-bg-alt);
    border-radius: 4px;
    border: 1px solid rgba(0, 153, 255, 0.2);
  }

  .phase-icon {
    font-size: 1.4rem;
  }

  .phase-line {
    width: 1px;
    flex-grow: 1;
    background: linear-gradient(to bottom, #eee 0%, #eee 50%, transparent 50%);
    background-size: 1px 20px;
    margin: 15px 0;
  }

  /* 最後の要素のラインを消す */
  .phase-card:last-child .phase-line {
    display: none;
  }

  .phase-content {
    flex-grow: 1;
    padding-bottom: 80px;
  }

  .phase-meta {
    margin-bottom: 20px;
  }

  .phase-title {
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.3em;
    color: #999;
    text-transform: uppercase;
    display: block;
    margin-bottom: 8px;
  }

  .phase-subtitle {
    font-size: 1.8rem;
    font-weight: 900;
    letter-spacing: -0.01em;
    margin: 0;
    color: #1a1a1a;
  }

  .phase-description {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #555;
    margin-bottom: 30px;
    max-width: 600px;
  }

  /* List Styling */
  .phase-article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .phase-article-list li a {
    display: flex;
    align-items: center;
    padding: 16px 20px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .phase-article-list li a:hover {
    background: var(--color-bg);
    border-color: var(--color-text);
    transform: translateX(5px);
    box-shadow: 4px 4px 0px var(--color-text);
  }

  .art-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
    flex-grow: 1;
  }

  .art-tag {
    font-size: 0.6rem;
    font-weight: 900;
    padding: 2px 6px;
    border-radius: 2px;
    margin-right: 12px;
    text-transform: uppercase;
  }

  .art-tag.must {
    background: #fee2e2;
    color: #ef4444;
  }

  .art-tag.pro {
    background: #f0fdf4;
    color: #22c55e;
  }

  .art-arrow {
    font-size: 0.8rem;
    color: #ccc;
    transition: transform 0.3s ease;
  }

  .phase-article-list li a:hover .art-arrow {
    transform: translateX(4px);
    color: #000;
  }

  /* Responsive Improvements */
  @media (max-width: 768px) {
    .roadmap-main-title {
      font-size: 2.2rem;
    }
    .phase-card {
      gap: 30px;
    }
    .phase-content {
      padding-bottom: 60px;
    }
    .phase-subtitle {
      font-size: 1.4rem;
    }
    .phase-article-list {
      grid-template-columns: 1fr;
    }
  }
</style>
