---
interface Props {
  badge: string;
  title: string;
  description: string;
  accent?: 'gold' | 'blue';
  theme?: 'light' | 'dark';
}

const { badge, title, description, accent = 'gold', theme = 'light' } = Astro.props;
---

<section class={`subpage-hero theme-${theme}`}>
  <div class="hero-inner">
    <div class="hero-content">
      <span class={`hero-badge accent-${accent}`}>{badge}</span>
      <h1 class="hero-title" set:html={title}></h1>
      <p class="hero-lead" set:html={description}></p>
    </div>
  </div>
</section>

<style>
  .subpage-hero {
    padding: 140px 0 100px;
    display: flex;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .subpage-hero.theme-light { background: #fff; }
  .subpage-hero.theme-dark { background: #000; }

  /* アクセントカラーに応じたグロー効果 */
  .subpage-hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(184, 134, 11, 0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .subpage-hero.theme-dark::before {
    background: radial-gradient(circle, rgba(184, 134, 11, 0.15) 0%, transparent 70%);
  }

  .subpage-hero:has(.accent-blue)::before {
    background: radial-gradient(circle, rgba(0, 153, 255, 0.05) 0%, transparent 70%);
  }

  .hero-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 100px 60px;
    position: relative;
    z-index: 1;
  }

  .theme-light .hero-inner { background: #fff; }
  .theme-dark .hero-inner { background: #000; }

  /* 1pxの緊張感：四隅の極細ボーダー */
  .hero-inner::before, .hero-inner::after {
    content: '';
    position: absolute;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(0,0,0,0.1);
    pointer-events: none;
  }
  .theme-dark .hero-inner::before, .theme-dark .hero-inner::after {
    border-color: rgba(184, 134, 11, 0.3);
  }

  .hero-inner::before { top: 0; left: 0; border-right: none; border-bottom: none; }
  .hero-inner::after { bottom: 0; right: 0; border-left: none; border-top: none; }

  .hero-content {
    text-align: center;
    max-width: 850px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 40px;
  }

  .hero-badge.accent-gold { color: #b8860b; }
  .hero-badge.accent-blue { color: #0099ff; }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 40px;
    letter-spacing: -0.01em;
  }

  .theme-light .hero-title { color: #000; }
  .theme-dark .hero-title { color: #fff; }

  .hero-lead {
    font-size: 1rem;
    line-height: 2;
    font-weight: 400;
    letter-spacing: 0.05em;
    max-width: 700px;
    margin: 0 auto;
  }

  .theme-light .hero-lead { color: #666; }
  .theme-dark .hero-lead { color: #888; }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 1.8rem;
    }
    .hero-inner {
      padding: 60px 24px;
    }
  }
</style>
