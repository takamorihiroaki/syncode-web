---
interface Props {
    title?: string;
    description?: string;
}

const { 
    title = "論理が生み出す成果：制作実績 (WORKS)", 
    description = "AIとの共創によって具現化されたプロジェクトの実例をWORKSページで紹介しています。" 
} = Astro.props;
---

<div class="cta-works-wrapper">
    <a href="/works/" class="cta-works-link">
        <div class="cta-content">
            <span class="cta-badge">Case Studies</span>
            <h3 class="cta-title">{title}</h3>
            <p class="cta-desc">{description}</p>
        </div>
        <div class="cta-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </div>
    </a>
</div>

<style>
    .cta-works-wrapper {
        margin: 60px 0 40px;
        width: 100%;
    }

    .cta-works-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 30px;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.03) 0%, rgba(2, 6, 23, 0.08) 100%);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        text-decoration: none;
        color: var(--color-text);
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
        overflow: hidden;
    }
    
    .cta-works-link:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
        border-color: #333;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.05) 0%, rgba(2, 6, 23, 0.1) 100%);
    }

    .cta-badge {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        background-color: var(--color-text);
        color: var(--color-bg, #fff);
        padding: 4px 8px;
        border-radius: 4px;
        margin-bottom: 12px;
    }

    .cta-title {
        font-size: 1.25rem;
        font-weight: 600;
        margin: 0 0 8px 0;
    }

    .cta-desc {
        font-size: 0.9rem;
        color: var(--color-text-light, #666);
        margin: 0;
        line-height: 1.5;
    }

    .cta-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: rgba(0, 0, 0, 0.05);
        color: var(--color-text);
        transition: transform 0.3s ease, background-color 0.3s ease, color 0.3s ease;
        flex-shrink: 0;
        margin-left: 20px;
    }

    .cta-works-link:hover .cta-arrow {
        transform: translateX(5px);
        background-color: var(--color-text);
        color: var(--color-bg, #fff);
    }

    @media (max-width: 600px) {
        .cta-works-link {
            flex-direction: column;
            align-items: flex-start;
            padding: 24px;
        }
        .cta-arrow {
            margin-left: 0;
            margin-top: 20px;
            align-self: flex-end;
        }
    }
</style>
