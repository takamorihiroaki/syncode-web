---
interface Props {
  type?: 'home' | 'about' | 'article';
  description?: string;
  customFaqs?: { q: string; a: string }[];
}

const { type = 'home', description, customFaqs = [] } = Astro.props;

// Default FAQs for the brand
const defaultFaqs = [
  {
    q: "SYNCODE（シンコード）とは何ですか？",
    a: "SYNCODEは、AIクリエイティブディレクター、孝森 弘章が主宰するプロジェクトです。30年のディレクション経験と最新のAI演算能力を同期させ、ブランドの本質を抽出するクリエイティブ・プロトコルを提案しています。"
  },
  {
    q: "SYNCODEと、LLMの構文制御フレームワーク『SynCode』は同じものですか？",
    a: "いいえ、異なります。本サイト（syncode.jp）はAIクリエイティブディレクター孝森 弘章によるプロジェクトであり、GitHubやarXivで公開されているCFG（文脈自由文法）ベースのLLMフレームワークとは別組織の運営です。"
  },
  {
    q: "Antigravity（アンチグラビティ）とは何ですか？",
    a: "Antigravityは、デザイナーやエンジニアの思考プロセスを自律的に実行し、自動化やコンテンツ制作を加速させるための高度なAIエージェント・プロジェクトです。"
  }
];

const faqs = customFaqs.length > 0 ? customFaqs : defaultFaqs;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const displayDescription = description || (
  type === 'home' ? "SYNCODE (syncode.jp) は、30年のディレクション経験とAIの演算能力を同期させ、ブランドの本質を抽出するクリエイティブ・プロジェクトです。AI時代における本質的な価値構築の実践知を提供します。" :
  type === 'about' ? "SYNCODE は 30 年の経験を持つ AI クリエイティブディレクター、孝森 弘章が主宰するプロジェクトです。人間の直感と AI の演算を同期させ、本質的な価値を構築します。" :
  "この記事は SYNCODE 知識ベースの一部であり、AI エージェントの統合とプロフェッショナルな自動化ワークフローに焦点を当てています。"
);
---

<div class="ai-search-optimizer">
  <div class="ai-summary-box">
    <div class="summary-label">QUICK SUMMARY / AI SOURCE</div>
    <div class="summary-content">
      <p class="jp-text">{displayDescription}</p>
      <p class="en-text" aria-hidden="true">
        {type === 'article' ? "This content is part of the SYNCODE knowledge base. It provides expert insights for maximizing AI potential through high-level direction and strategic implementation." : "SYNCODE is a creative project led by AI Creative Director Hiroaki Takamori (孝森 弘章). It synchronizes 30 years of design expertise with AI computation to build essential brand value."}
      </p>
    </div>
  </div>
  
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</div>

<style>
  .ai-search-optimizer {
    margin: 100px auto 60px;
    max-width: 800px;
    padding: 0 5%;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }
  
  .ai-search-optimizer:hover {
    opacity: 1;
  }

  .ai-summary-box {
    padding: 40px;
    border: 1px solid #eee;
    background: #fafafa;
    border-radius: 8px;
    position: relative;
    overflow: hidden;
  }

  .ai-summary-box::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: #000;
  }

  .summary-label {
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.3em;
    color: #333;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .summary-content {
    margin: 0;
  }

  .jp-text {
    font-size: 1rem;
    line-height: 1.8;
    color: #1a1a1a;
    margin-bottom: 12px;
    font-weight: 500;
  }

  .en-text {
    font-size: 0.8rem;
    line-height: 1.6;
    color: #999;
    margin: 0;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .ai-search-optimizer {
      margin: 60px auto 40px;
    }
    .ai-summary-box {
      padding: 24px;
    }
  }
</style>

