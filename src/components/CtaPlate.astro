---
interface Props {
  title: string;
  excerpt?: string;
  image: string;
  link: string;
  label?: string; // "NEXT STEP", "RECOMMENDED", etc.
  category?: string;
}

const { title, excerpt, image, link, label = "RECOMMENDED", category } = Astro.props;
---

<div class="cta-plate">
  <a href={link} class="plate-anchor">
    <div class="plate-visual">
      <img src={image} alt={`${title}のサムネイル`} loading="lazy" />
      <div class="plate-overlay"></div>
    </div>
    <div class="plate-content">
      <div class="plate-header">
        <span class="plate-label">{label}</span>
        {category && <span class="plate-category">{category}</span>}
      </div>
      <h3 class="plate-title">{title}</h3>
      {excerpt && <p class="plate-excerpt">{excerpt}</p>}
      <div class="plate-footer">
        <span class="action-text">記事を読む</span>
        <div class="action-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </div>
      </div>
    </div>
  </a>
</div>

<style>
  .cta-plate {
    margin: 80px 0;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  .cta-plate:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: 0 40px 80px rgba(0,0,0,0.12);
    border-color: rgba(0, 153, 255, 0.3);
  }

  .plate-anchor {
    display: grid;
    grid-template-columns: 320px 1fr;
    text-decoration: none;
    color: inherit;
    min-height: 240px;
  }

  .plate-visual {
    position: relative;
    overflow: hidden;
    background: #000;
  }

  .plate-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s ease;
  }

  .cta-plate:hover .plate-visual img {
    transform: scale(1.08);
  }

  .plate-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(0,0,0,0.2) 0%, transparent 100%);
  }

  .plate-content {
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .plate-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .plate-label {
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.25em;
    color: #0099ff;
    text-transform: uppercase;
  }

  .plate-category {
    font-size: 0.65rem;
    font-weight: 800;
    color: #999;
    letter-spacing: 0.1em;
  }

  .plate-title {
    font-size: 1.4rem;
    font-weight: 900;
    margin: 0 0 12px 0;
    line-height: 1.5;
    color: #1a1a1a;
  }

  .plate-excerpt {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
    margin: 0 0 24px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .plate-footer {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .action-text {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: #1a1a1a;
  }

  .action-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: #000;
    color: #fff;
    border-radius: 50%;
    transition: all 0.3s ease;
  }

  .cta-plate:hover .action-arrow {
    transform: translateX(12px) scale(1.1);
    background: #000;
    box-shadow: 0 4px 15px rgba(0, 153, 255, 0.4);
  }

  @media (max-width: 850px) {
    .plate-anchor {
      grid-template-columns: 1fr;
    }
    .plate-visual {
      height: 200px;
    }
    .plate-content {
      padding: 30px;
    }
    .plate-title {
      font-size: 1.2rem;
    }
  }
</style>
