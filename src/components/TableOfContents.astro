---
/*
  TableOfContents.astro
  Astroのheadingsを受け取り、目次を生成するコンポーネント
*/
interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;

// h2 と h3 のみを抽出
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

if (filteredHeadings.length < 2) return null; // 見出しが少ない場合は表示しない
---

<nav class="toc-container">
  <div class="toc-header">
    <span class="toc-icon">📁</span>
    <span class="toc-title">INDEX</span>
  </div>
  <ul class="toc-list">
    {
      filteredHeadings.map((heading) => (
        <li class={`toc-item depth-${heading.depth}`}>
          <a href={`#${heading.slug}`}>
            <span class="toc-number"></span>
            <span class="toc-text">{heading.text}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .toc-container {
    margin: 48px 0;
    padding: 32px 40px;
    background: #fdfdfd;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    max-width: 100%;
  }

  .toc-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
  }

  .toc-icon {
    font-size: 0.9rem;
    opacity: 0.5;
  }

  .toc-title {
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    color: var(--color-text-dim);
    text-transform: uppercase;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: toc-h2;
  }

  .toc-item {
    margin-bottom: 14px;
  }

  .toc-item:last-child {
    margin-bottom: 0;
  }

  .toc-item a {
    text-decoration: none;
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    transition: all 0.3s var(--ease-out-expo);
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .toc-item a:hover {
    color: var(--color-text);
    transform: translateX(4px);
  }

  /* Hierarchical Numbering */
  .toc-item.depth-2 {
    counter-increment: toc-h2;
    counter-reset: toc-h3;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 20px;
  }

  .toc-item.depth-2:first-child {
    margin-top: 0;
  }

  .toc-item.depth-2 .toc-number::before {
    content: counter(toc-h2) ". ";
    color: var(--color-text-dim);
    font-weight: 400;
    font-size: 0.85rem;
    min-width: 1.5em;
    display: inline-block;
  }

  .toc-item.depth-3 {
    counter-increment: toc-h3;
    padding-left: 28px; /* H2の番号＋ギャップ分をインデント */
    font-size: 0.9rem;
    font-weight: 400;
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .toc-item.depth-3 .toc-number::before {
    content: counter(toc-h2) "." counter(toc-h3) ". ";
    color: #bbb;
    font-weight: 400;
    font-size: 0.75rem;
    min-width: 2.2em;
    display: inline-block;
  }

  .toc-text {
    flex: 1;
  }

  @media (max-width: 640px) {
    .toc-container {
      padding: 24px;
      margin: 32px 0;
    }
    .toc-item.depth-3 {
      padding-left: 20px;
    }
  }
</style>
