---
interface Link {
  text: string;
  href: string;
}

interface Props {
  title?: string;
  links: Link[];
}

const { title = "🎯 次に読むべき「最速への鍵」", links } = Astro.props;
---

<div class="related-links-container">
  <h3 class="related-title">{title}</h3>
  <div class="links-wrapper">
    {links.map((link) => (
      <a href={link.href} class="related-link-item">
        <span class="link-label">{link.text}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .related-links-container {
    margin: 48px 0;
    padding: 0;
  }

  .related-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 24px;
    color: #333;
    letter-spacing: 0.05em;
  }

  .links-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .related-link-item {
    display: block;
    padding: 8px 0;
    text-decoration: none !important;
    color: #555;
    background: transparent;
    transition: color 0.3s ease;
    position: relative;
    width: fit-content;
  }

  .related-link-item:hover {
    color: #000;
  }

  .link-label {
    font-size: 0.95rem;
    line-height: 1.6;
    display: inline-block;
    font-weight: 500;
    padding-bottom: 2px;
    text-decoration: none !important;
    background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition: background-size 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .related-link-item:hover .link-label {
    background-size: 100% 1px;
  }

  @media (max-width: 640px) {
    .related-links-container {
      margin: 40px 0;
    }
    .link-label {
      font-size: 0.9rem;
    }
  }
</style>
