---
import { getCollection } from 'astro:content';
import ArticleCard from './ArticleCard.astro';

interface Link {
  text?: string;
  href: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  links: Link[];
}

const { 
  title = "NEXT STEP", 
  subtitle = "この記事の内容を実践するために次にやるべきこと",
  links 
} = Astro.props;

// URLから記事のID（slug）を抽出する関数
const getSlugFromHref = (href: string) => {
  const match = href.match(/\/articles\/([^\/]+)\/?/);
  return match ? match[1] : null;
};

// 全記事を取得して、指定されたリンクに一致する記事を探す
const allArticles = await getCollection('articles');
const relatedArticles = links.map(link => {
  const slug = getSlugFromHref(link.href);
  const article = allArticles.find(a => a.id === slug);
  return article ? { ...article, customTitle: link.text } : null;
}).filter(Boolean);

---

<div class="next-step-navigator">
  <div class="navigator-header">
    <span class="navigator-badge">{title}</span>
    <p class="navigator-subtitle">{subtitle}</p>
  </div>
  <div class="links-grid">
    {relatedArticles.map((article) => (
      <div class="related-card-wrapper">
        <ArticleCard article={article} variant="standard" />
      </div>
    ))}
  </div>
</div>

<style>
  .next-step-navigator {
    margin: 80px 0;
    padding: 40px;
    background: #fdfdfd;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
  }

  .navigator-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .navigator-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    color: #2563eb;
    background: #eff6ff;
    padding: 6px 16px;
    border-radius: 20px;
    margin-bottom: 16px;
  }

  .navigator-subtitle {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    letter-spacing: 0.05em;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    align-items: start;
  }

  .related-card-wrapper {
    min-width: 0;
  }

  @media (max-width: 768px) {
    .next-step-navigator {
      padding: 24px;
      margin: 60px 0;
    }
    .navigator-subtitle {
      font-size: 0.95rem;
    }
    .links-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
