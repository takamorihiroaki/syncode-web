---
import { getCollection } from 'astro:content';
import ArticleCard from './ArticleCard.astro';

interface Link {
  text?: string;
  href: string;
}

interface Props {
  title?: string;
  links: Link[];
}

const { title = "🎯 次に読むべき「最速への鍵」", links } = Astro.props;

// URLから記事のID（slug）を抽出する関数
const getSlugFromHref = (href: string) => {
  const match = href.match(/\/articles\/([^\/]+)\/?/);
  return match ? match[1] : null;
};

// 全記事を取得して、指定されたリンクに一致する記事を探す
const allArticles = await getCollection('articles');
const relatedArticles = links.map(link => {
  const slug = getSlugFromHref(link.href);
  const article = allArticles.find(a => a.id === slug);
  return article ? { ...article, customTitle: link.text } : null;
}).filter(Boolean);

---

<div class="related-links-container">
  <h3 class="related-title">{title}</h3>
  <div class="links-grid">
    {relatedArticles.map((article) => (
      <div class="related-card-wrapper">
        <ArticleCard article={article} variant="standard" />
      </div>
    ))}
  </div>
</div>

<style>
  .related-links-container {
    margin: 64px 0;
    padding: 32px 0;
    border-top: 1px solid #f0f0f0;
  }

  .related-title {
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 32px;
    color: #000;
    letter-spacing: 0.05em;
    text-align: center;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .related-card-wrapper {
    min-width: 0;
  }

  @media (max-width: 768px) {
    .links-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .related-links-container {
      margin: 48px 0;
    }
  }
</style>
