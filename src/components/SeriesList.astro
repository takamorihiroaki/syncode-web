---
import { getCollection } from "astro:content";

interface Props {
  series?: string;
  id?: string;
}

const { series: propSeries, id: propId } = Astro.props;

// Fetch all articles
const allArticles = await getCollection("articles");

// Current article info
const currentPath = Astro.url.pathname;
const currentArticle = allArticles.find(a => currentPath.replace(/\/$/, "").split('/').pop() === a.id);
const currentSeries = propSeries || currentArticle?.data.series;

if (!currentSeries) {
  return null;
}

// Normalize series name
const getBaseSeriesName = (name: string) => {
  return name.replace(/【全\d+回】/, "").trim();
};

const baseSeriesName = getBaseSeriesName(currentSeries);

// Filter and sort articles in this series
const seriesArticles = allArticles
  .filter(a => a.data.series && getBaseSeriesName(a.data.series) === baseSeriesName)
  .sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));

const n = seriesArticles.length;

// Find next article
const currentIndex = seriesArticles.findIndex(a => a.id === currentArticle?.id);
const nextArticle = currentIndex !== -1 && currentIndex < seriesArticles.length - 1 ? seriesArticles[currentIndex + 1] : null;

// Display name
const displaySeriesName = `連載のご案内（全${n}回）`;
---

<div class="series-nav-container">
  <h2>{displaySeriesName}</h2>
  <ul class="series-nav-list">
    {seriesArticles.map((article) => {
      const isCurrent = article.id === currentArticle?.id;
      const cleanTitle = article.data.title.replace(/【.*?】/, "").split("｜")[0].trim();
      
      return (
        <li>
          {isCurrent ? (
            <div class="series-nav-row series-current-item">
              <span class="series-label-col">STEP {article.data.seriesOrder}：</span>
              <span class="series-title-col">{cleanTitle}（本記事）</span>
            </div>
          ) : (
            <a href={`/articles/${article.id}/`} class="series-nav-row series-link-row">
              <div class="series-label-col">STEP {article.data.seriesOrder}：</div>
              <div class="series-title-col">
                <span class="series-animated-underline">{cleanTitle}</span>
              </div>
            </a>
          )}
        </li>
      );
    })}
  </ul>

  {nextArticle && (
    <div class="series-next-banner-box">
      <a href={`/articles/${nextArticle.id}/`} class="series-next-anchor">
        <div class="series-next-grid">
          <div class="series-next-label-group">
            <span class="series-next-emoji">👉</span>
            <span class="series-next-label-text">次なるステップ　STEP {nextArticle.data.seriesOrder}：</span>
          </div>
          <div class="series-next-title-wrapper">
             <span class="series-animated-underline">
               {nextArticle.data.title.replace(/【.*?】/, "").split("｜")[0].trim()}
             </span>
          </div>
        </div>
      </a>
    </div>
  )}
</div>

<style>
  .series-nav-container h2 {
    font-size: 1.35rem;
    font-weight: 400;
    margin: 60px 0 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f0f0f0;
  }

  .series-nav-list {
    list-style: none !important;
    padding-left: 0 !important;
    margin: 0;
  }

  .series-nav-list li {
    margin-bottom: 1.25em;
  }

  /* グリッドレイアウトによる「ぶら下げインデント」の実現 */
  .series-nav-row {
    display: grid !important;
    /* ラベルの幅を固定することで、複数行にわたるタイトルの開始位置を垂直に揃える */
    grid-template-columns: 5.8em 1fr !important;
    gap: 0 !important;
    line-height: 1.7;
    text-decoration: none !important;
    /* グローバルなホバー下線を無効化 */
    background-image: none !important;
    color: inherit;
    align-items: start;
    text-align: left !important;
  }

  .series-label-col {
    white-space: nowrap;
    color: #444;
    display: block !important;
    font-weight: 400;
  }

  .series-title-col {
    word-break: normal;
    overflow-wrap: anywhere;
    display: block !important;
    text-align: left !important;
  }

  .series-current-item {
    font-weight: 700;
    color: #000;
  }

  .series-current-item .series-label-col {
    font-weight: 700;
    color: #000;
  }

  /* アンダーラインアニメーション */
  .series-animated-underline {
    display: inline;
    background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition: background-size 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    padding-bottom: 2px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  .series-link-row:hover .series-animated-underline,
  .series-next-anchor:hover .series-animated-underline {
    background-size: 100% 1px;
    color: #000;
  }

  /* Next Step Banner */
  .series-next-banner-box {
    margin: 3.5em 0;
    padding: 1.5em;
    background: #fafafa;
    border-radius: 4px;
    text-align: left !important;
  }

  .series-next-anchor {
    color: #333;
    text-decoration: none !important;
    /* グローバルなホバー下線を無効化 */
    background-image: none !important;
    display: block !important;
  }

  .series-next-grid {
    display: grid !important;
    /* 次のステップ用のラベル幅を固定 */
    grid-template-columns: auto 1fr !important; 
    gap: 0 !important;
    align-items: start;
    line-height: 1.7;
  }

  .series-next-label-group {
    display: flex !important;
    align-items: center;
    white-space: nowrap;
    padding-right: 0.5em;
  }

  .series-next-emoji {
    font-size: 1.1rem;
    margin-right: 0.6em;
  }

  .series-next-label-text {
    font-weight: 400;
  }

  .series-next-title-wrapper {
    word-break: normal;
    overflow-wrap: anywhere;
    text-align: left !important;
  }

  @media (max-width: 640px) {
    .series-nav-row,
    .series-next-grid {
      grid-template-columns: 1fr !important;
    }
    
    .series-label-col,
    .series-next-label-group {
      margin-bottom: 0.2em;
    }
  }
</style>
