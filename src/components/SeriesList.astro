---
import { getCollection } from "astro:content";

interface Props {
  series?: string;
  id?: string;
}

const { series: propSeries, id: propId } = Astro.props;

// Fetch all articles
const allArticles = await getCollection("articles");

// Current article info
const currentPath = Astro.url.pathname;
const currentArticle = allArticles.find(a => currentPath.replace(/\/$/, "").split('/').pop() === a.id);
const currentSeries = propSeries || currentArticle?.data.series;

if (!currentSeries) {
  return null;
}

// Normalize series name
const getBaseSeriesName = (name: string) => {
  return name.replace(/【全\d+回】/, "").trim();
};

const baseSeriesName = getBaseSeriesName(currentSeries);

// Filter and sort articles in this series
const seriesArticles = allArticles
  .filter(a => a.data.series && getBaseSeriesName(a.data.series) === baseSeriesName)
  .sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));

const n = seriesArticles.length;

// Find next article
const currentIndex = seriesArticles.findIndex(a => a.id === currentArticle?.id);
const nextArticle = currentIndex !== -1 && currentIndex < seriesArticles.length - 1 ? seriesArticles[currentIndex + 1] : null;

// Display name
const displaySeriesName = `連載のご案内（全${n}回）`;
---

<div class="series-nav-container">
  <h2>{displaySeriesName}</h2>
  <ul class="series-nav-list">
    {seriesArticles.map((article) => {
      const isCurrent = article.id === currentArticle?.id;
      const cleanTitle = article.data.title.replace(/【.*?】/, "").split("｜")[0].trim();
      
      return (
        <li>
          {isCurrent ? (
            <div class="grid-row">
              <span class="grid-label">STEP {article.data.seriesOrder}：</span>
              <span class="grid-title current-article">{cleanTitle}（本記事）</span>
            </div>
          ) : (
            <a href={`/articles/${article.id}/`} class="grid-row link-row">
              <span class="grid-label">STEP {article.data.seriesOrder}：</span>
              <span class="grid-title animated-title"><span>{cleanTitle}</span></span>
            </a>
          )}
        </li>
      );
    })}
  </ul>

  {nextArticle && (
    <div class="article-link-list">
      <div class="grid-row next-link-container">
        <span class="grid-label next-label-width">👉 <strong>次なるステップ　STEP {nextArticle.data.seriesOrder}：</strong></span>
        <a href={`/articles/${nextArticle.id}/`} class="grid-title animated-title next-title-link">
          <span>{nextArticle.data.title.replace(/【.*?】/, "").split("｜")[0].trim()}</span>
        </a>
      </div>
    </div>
  )}
</div>

<style>
  .series-nav-container h2 {
    font-size: 1.35rem;
    font-weight: 400;
    margin: 40px 0 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f0f0f0;
  }

  .series-nav-list {
    list-style: none !important;
    padding-left: 0 !important;
    margin: 0;
  }

  .series-nav-list li {
    margin-bottom: 0.8em;
  }

  /* 究極の整列：Gridによる2カラム固定 */
  .grid-row {
    display: grid;
    grid-template-columns: min-content 1fr; /* ラベル幅はコンテンツに合わせ、タイトルは残りを埋める */
    align-items: start;
    line-height: 1.7;
    text-decoration: none !important;
    background-image: none !important;
    color: inherit;
  }

  .grid-label {
    white-space: nowrap;
    padding-right: 0.6em; /* ラベルとタイトルの余白 */
  }

  .next-label-width {
    /* 「👉 次なるステップ STEP X：」は長いので、しっかり幅を確保 */
    padding-right: 0.8em;
  }

  /* 行を跨いでも2列目に留まる block コンテナ */
  .grid-title {
    display: block; 
    text-decoration: none !important;
    background-image: none !important;
  }

  .current-article {
    font-weight: 700;
  }

  /* アニメーション：inline要素に適用することで、全行に下線を引く */
  .animated-title span {
    display: inline;
    background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition: background-size 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    padding-bottom: 2px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  .link-row:hover .animated-title span,
  .next-title-link:hover span {
    background-size: 100% 1px;
    color: #000;
  }

  .article-link-list {
    margin: 2em 0;
    padding: 1.5em;
    background: #fafafa;
    border-radius: 4px;
    font-size: 1rem;
  }

  .next-link-container {
    line-height: 1.6;
  }

  .next-title-link {
    color: inherit;
    text-decoration: none !important;
  }

  /* レスポンシブ対応：狭い画面でもずれない */
  @media (max-width: 640px) {
    .grid-label {
      padding-right: 0.4em;
    }
    .next-link-container {
      display: block; /* モバイルの極小画面では、ラベルとタイトルを分けることも検討可能だが、一旦Grid維持 */
    }
    .next-label-width {
      display: block;
      margin-bottom: 4px;
    }
  }
</style>
