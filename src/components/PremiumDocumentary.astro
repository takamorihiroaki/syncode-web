---
import { getCollection } from "astro:content";
import ArticleCard from "./ArticleCard.astro";

const seriesIds = [
  'ga4-analysis-discovery',
  'ga4-sync-technical-guide',
  'ai-collaboration-ip-filter',
  'data-driven-seo-optimization'
];

const allArticles = await getCollection("articles");
const seriesArticles = seriesIds
  .map(id => allArticles.find(a => a.id === id))
  .filter(Boolean);
---

<section class="premium-documentary">
  <div class="documentary-header">
    <div class="header-line"></div>
    <span class="sub-label">Featured Story</span>
    <h2 class="series-title">AI Agent Co-creation Chronicles</h2>
    <div class="series-subtitle">【全4回】実録：GA4分析からSEO改善まで</div>
    <p class="series-desc">
      分析から課題発見、そしてAIとの共同作業でサイトを成長させていく軌跡を、全4回のストーリーでまとめました。
    </p>
  </div>

  <div class="documentary-grid">
    {seriesArticles.map((article, index) => (
      <ArticleCard article={article} variant="premium" step={index + 1} />
    ))}
  </div>
</section>

<div class="filter-bar-wrapper">
  <div class="filter-bar">
    <div class="filter-inner">
      <a href="#" class="filter-item active">ALL</a>
      <a href="#" class="filter-item">AI戦略</a>
      <a href="#" class="filter-item">AIツール</a>
      <a href="#" class="filter-item">技術検証</a>
      <a href="#" class="filter-item">自動化</a>
      <a href="#" class="filter-item secondary">効率化テクニック</a>
    </div>
  </div>
</div>

<style>
  .premium-documentary {
    background: #000;
    padding: 100px 0 60px; /* ボトムの余白を調整 */
    margin: 60px auto 40px; /* 下部マージンを減らし、フィルターとの距離を調整 */
    max-width: 1100px;
    width: 100%;
    border-radius: 20px;
    position: relative;
    color: #fff;
    overflow: hidden;
  }

  /* ...中略（header, labels, gridなどのスタイルは維持）... */
  
  .documentary-header {
    max-width: 1000px;
    margin: 0 auto 80px;
    padding: 0 20px;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .header-line {
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    margin: 0 auto 40px;
  }

  .sub-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    color: #b8860b;
    letter-spacing: 0.4em;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .series-title {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: 0.15em;
    line-height: 1.3;
    text-transform: uppercase;
    color: #fff;
  }

  .series-subtitle {
    font-size: 1.1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 24px;
    letter-spacing: 0.05em;
  }

  .series-desc {
    font-size: 0.95rem;
    color: #ccc;
    line-height: 1.8;
    max-width: 650px;
    margin: 0 auto;
    letter-spacing: 0.02em;
  }

  .documentary-grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  @media (max-width: 1024px) {
    .documentary-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 30px;
    }
  }

  @media (max-width: 640px) {
    .documentary-grid {
      grid-template-columns: 1fr;
    }
    .series-title {
      font-size: 1.6rem;
    }
  }

  /* Filter Bar Style - 外側（白背景）向けに独立性を強化 */
  .filter-bar-wrapper {
    max-width: 1100px;
    margin: 40px auto 100px; /* 上部マージンを少し増やして独立させる */
    padding: 0 20px;
  }

  .filter-bar {
    border-top: 1px solid #f0f0f0; /* より繊細なラインに */
    padding-top: 60px;
  }

  .filter-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 40px; /* アイテム間の距離を最適化 */
  }

  .filter-item {
    font-size: 0.8rem;
    color: #555; /* ベースのコントラストを強化 (#888 -> #555) */
    text-decoration: none !important;
    letter-spacing: 0.2em; /* 文字間隔を広げ、高級感を演出 */
    position: relative;
    padding-bottom: 12px;
    transition: color 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    font-weight: 700;
    text-transform: uppercase;
  }

  /* ホバー & アクティブ時の色変化 */
  .filter-item:hover, .filter-item.active {
    color: #000;
  }

  /* アンダーライン：初期状態（非表示） */
  .filter-item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: #000;
    transform: scaleX(0); /* 横幅0から開始 */
    transform-origin: center;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  /* ホバー時に線を伸ばす */
  .filter-item:hover::after {
    transform: scaleX(0.6); /* ホバー時は控えめに伸ばす */
  }

  /* アクティブ時は線をフルで表示 */
  .filter-item.active::after {
    transform: scaleX(1);
    background: #000;
  }

  .filter-item.secondary {
    color: #999;
    font-size: 0.75rem;
    font-weight: 500;
  }
  
  .filter-item.secondary:hover {
    color: #666;
  }

  @media (max-width: 768px) {
    .filter-inner {
      gap: 20px 30px;
    }
    .filter-item {
      font-size: 0.75rem;
      letter-spacing: 0.1em;
    }
  }
</style>
