---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import SubPageHero from "../../components/SubPageHero.astro";
import AISearchOptimizer from "../../components/AISearchOptimizer.astro";
import { tagToSlug } from "../../utils/tag";

export async function getStaticPaths() {
    const allArticles = await getCollection("articles");
    
    // Tag to Articles Map (Lowercased slug as key)
    const tagMap = new Map();
    
    allArticles.forEach(article => {
        const tags = article.data.tags || [];
        tags.forEach(tag => {
            if (!tag) return;
            const slug = tagToSlug(tag);
            if (!slug) return;
            
            if (!tagMap.has(slug)) {
                tagMap.set(slug, {
                    displayName: tag,
                    articles: []
                });
            }
            tagMap.get(slug).articles.push(article);
        });
    });
    
    return Array.from(tagMap.entries()).map(([slug, data]) => {
        const sortedArticles = data.articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
        
        return {
            params: { tag: slug },
            props: { tag: data.displayName, articles: sortedArticles }
        };
    });
}

const { tag, articles } = Astro.props;

// 関連タグの計算（このタグが含まれる記事に含まれる他のタグを抽出）
const relatedTags = [...new Set(
    articles.flatMap(article => article.data.tags || [])
        .filter(t => t && t !== tag)
)].slice(0, 8);
---

<BaseLayout title={`${tag} - タグ一覧`} noindex={articles.length < 3}>
    <SubPageHero 
        badge="Tag"
        title={`#${tag}`}
        description={`「${tag}」に関する知見と情報のアーカイブ。<br/>全 ${articles.length} 件の記事を公開しています。`}
        accent="blue"
    />

    <div class="tag-container">
        {relatedTags.length > 0 && (
            <div class="related-tags-container">
                <span class="related-tags-label">Related Signals:</span>
                <div class="related-tags-list">
                    {relatedTags.map(rt => (
                        <a href={`/tag/${tagToSlug(rt)}/`} class="related-tag-link">#{rt}</a>
                    ))}
                </div>
            </div>
        )}

        <div class="article-grid">
            {
                articles.map((article) => (
                    <ArticleCard article={article} variant="standard" />
                ))
            }
        </div>
        
        <div class="archive-footer">
            <div class="footer-nav-links">
                <a href="/articles/#tag-cloud" class="back-link">
                    <span class="link-label">System Library</span>
                    <span class="link-text">すべてのタグを見る</span>
                </a>
                <a href="/articles/" class="back-link">
                    <span class="link-label">Back to Library</span>
                    <span class="link-text">記事一覧に戻る</span>
                </a>
            </div>
        </div>
    </div>
    <AISearchOptimizer type="standard" />
</BaseLayout>

<style>
    .tag-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 60px 20px 140px;
    }

    .related-tags-container {
        margin-bottom: 80px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        padding: 40px;
        background: #fafafa;
        border: 1px solid #f0f0f0;
    }

    .related-tags-label {
        font-family: var(--font-heading);
        font-size: 0.65rem;
        font-weight: 800;
        color: #ccc;
        text-transform: uppercase;
        letter-spacing: 0.3em;
    }

    .related-tags-list {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .related-tag-link {
        font-family: var(--font-heading);
        font-size: 0.85rem;
        font-weight: 800;
        color: #888;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .related-tag-link:hover {
        color: #000;
    }

    .article-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 80px 40px;
    }

    @media (max-width: 1024px) {
        .article-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .article-grid {
            grid-template-columns: 1fr;
        }
    }

    .archive-footer {
        text-align: center;
        margin-top: 120px;
        padding-top: 60px;
        border-top: 1px solid #f0f0f0;
    }

    .footer-nav-links {
        display: flex;
        justify-content: center;
        gap: 60px;
        flex-wrap: wrap;
    }

    .back-link {
        text-decoration: none;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        transition: all 0.4s var(--ease-out-expo);
    }

    .back-link:hover {
        transform: translateY(-4px);
    }

    .link-label {
        font-family: var(--font-heading);
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: #ccc;
    }

    .link-text {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 0.2em;
        color: #000;
        padding-bottom: 4px;
        border-bottom: 2px solid #000;
    }
</style>
