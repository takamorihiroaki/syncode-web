---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { tagToSlug } from "../../utils/tag";

export async function getStaticPaths() {
    const allArticles = await getCollection("articles");
    
    // Tag to Articles Map (Lowercased slug as key)
    const tagMap = new Map();
    
    allArticles.forEach(article => {
        const tags = article.data.tags || [];
        tags.forEach(tag => {
            if (!tag) return;
            const slug = tagToSlug(tag);
            if (!slug) return;
            
            if (!tagMap.has(slug)) {
                tagMap.set(slug, {
                    displayName: tag,
                    articles: []
                });
            }
            tagMap.get(slug).articles.push(article);
        });
    });
    
    return Array.from(tagMap.entries()).map(([slug, data]) => {
        const sortedArticles = data.articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
        
        return {
            params: { tag: slug },
            props: { tag: data.displayName, articles: sortedArticles }
        };
    });
}

const { tag, articles } = Astro.props;

// 関連タグの計算（このタグが含まれる記事に含まれる他のタグを抽出）
const relatedTags = [...new Set(
    articles.flatMap(article => article.data.tags || [])
        .filter(t => t && t !== tag)
)].slice(0, 8);
---

<BaseLayout title={`${tag} - タグ一覧`} noindex={articles.length < 3}>
    <div class="archive-header">
        <div class="section-title-wrapper-tag">
            <span class="tag-label-top">Tag</span>
            <h1 class="section-title-tag">{tag}</h1>
            <p class="tag-count-label">{articles.length}件の記事</p>
        </div>
    </div>

    {relatedTags.length > 0 && (
        <div class="related-tags-container">
            <span class="related-tags-label">Related:</span>
            <div class="related-tags-list">
                {relatedTags.map(rt => (
                    <a href={`/tag/${tagToSlug(rt)}/`} class="related-tag-link">#{rt}</a>
                ))}
            </div>
        </div>
    )}

    <div class="article-grid">
        {
            articles.map((article) => (
                <ArticleCard article={article} variant="standard" />
            ))
        }
    </div>
    
    <div class="archive-footer">
        <div class="footer-nav-links">
            <a href="/articles/#tag-cloud" class="back-link secondary">すべてのタグを見る</a>
            <a href="/" class="back-link">TOPページに戻る</a>
        </div>
    </div>
</BaseLayout>

<style>
    .archive-header {
        text-align: center;
        margin-bottom: 60px;
    }

    .section-title-wrapper-tag {
        display: inline-block;
        padding-bottom: 24px;
        border-bottom: 1px solid #eee;
    }

    .tag-label-top {
        display: block;
        font-size: 0.75rem;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        margin-bottom: 12px;
    }

    .section-title-tag {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: #000;
        margin: 0 0 8px 0;
    }

    .tag-count-label {
        font-size: 0.85rem;
        color: #888;
        letter-spacing: 0.05em;
        margin: 0;
    }

    .related-tags-container {
        max-width: 1100px;
        margin: 0 auto 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
        padding: 0 20px;
    }

    .related-tags-label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #bbb;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .related-tags-list {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .related-tag-link {
        font-size: 0.85rem;
        color: #666;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .related-tag-link:hover {
        color: #000;
        text-decoration: underline;
    }

    .article-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 60px 40px;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
    }

    @media (max-width: 1024px) {
        .article-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .article-grid {
            grid-template-columns: 1fr;
        }
    }

    .archive-footer {
        text-align: center;
        margin-top: 100px;
        padding-top: 60px;
        border-top: 1px solid #f0f0f0;
    }

    .footer-nav-links {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .back-link {
        display: inline-block;
        padding: 14px 32px;
        background: #000;
        color: #fff;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 700;
        transition: all 0.3s ease;
    }

    .back-link.secondary {
        background: #fff;
        color: #000;
        border: 1px solid #eee;
    }

    .back-link:hover {
        background: #333;
        transform: translateY(-2px);
    }

    .back-link.secondary:hover {
        background: #f8f8f8;
        border-color: #ddd;
    }
</style>
