---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import SubPageHero from "../../components/SubPageHero.astro";

export async function getStaticPaths() {
    const allArticles = await getCollection("articles");
    
    // Get unique categories and normalize them (lowercase for URL)
    const categories = [...new Set(allArticles.map(article => article.data.category).filter(Boolean))];
    
    return categories.map(category => {
        if (!category) return null;
        const filteredArticles = allArticles.filter(article => article.data.category === category)
            .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
            
        return {
            params: { category: category.toLowerCase() },
            props: { category, articles: filteredArticles }
        };
    });
}

const { category, articles } = Astro.props;
---

<BaseLayout title={`${category} - カテゴリー一覧`} noindex={articles.length < 3}>
    <SubPageHero 
        badge="Category"
        title={category}
        description={`「${category}」に関する技術と知見のアーカイブ。<br/>全 ${articles.length} 件の記事を公開しています。`}
        accent="gold"
    />

    <div class="category-container">
        <div class="article-grid">
            {
                articles.map((article) => (
                    <ArticleCard article={article} variant="standard" />
                ))
            }
        </div>
        
        <div class="archive-footer">
            <a href="/articles/" class="back-link">
                <span class="link-label">Back to Library</span>
                <span class="link-text">記事一覧に戻る</span>
            </a>
        </div>
    </div>
</BaseLayout>

<style>
    .category-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 60px 20px 140px;
    }

    .article-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 80px 40px;
    }

    @media (max-width: 1024px) {
        .article-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .article-grid {
            grid-template-columns: 1fr;
        }
    }

    .archive-footer {
        text-align: center;
        margin-top: 120px;
        padding-top: 60px;
        border-top: 1px solid #f0f0f0;
    }

    .back-link {
        text-decoration: none;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        transition: all 0.4s var(--ease-out-expo);
    }

    .back-link:hover {
        transform: translateY(-4px);
    }

    .link-label {
        font-family: var(--font-heading);
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: #ccc;
    }

    .link-text {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 0.2em;
        color: #000;
        padding-bottom: 4px;
        border-bottom: 2px solid #000;
    }
</style>
