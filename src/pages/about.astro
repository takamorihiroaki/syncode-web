---
import BaseLayout from '../layouts/BaseLayout.astro';
import AISearchOptimizer from '../components/AISearchOptimizer.astro';
---

<BaseLayout 
    title="ABOUT | SYNCODE"
    description="SYNCODE Identity & Strategy. 30年のディレクション経験とAIの演算能力を同期させ、ブランドの本質を抽出するクリエイティブ・プロトコルについて。"
>
    <style>
        .about-layout {
            max-width: 1000px; /* 刷新後の1000px基準を復元 */
            margin: 0 auto;
            padding: 100px 5% 80px;
            color: var(--color-text);
            line-height: 2.2;
            letter-spacing: 0.1em;
        }

        .about-page-title {
            font-size: 0.8rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5em;
            color: #999;
            margin: 0 0 100px 0;
            padding-bottom: 20px;
            border-bottom: 2px solid #1a1a1a;
        }

        .about-section {
            margin-bottom: 120px;
            display: flex;
            flex-direction: column;
            max-width: 850px; /* 700pxから850pxへ拡張 */
        }

        .about-section:last-child {
            margin-bottom: 0px;
        }

        .about-section h2 { 
            font-size: 0.8rem;
            font-weight: 800; 
            text-transform: uppercase; 
            letter-spacing: 0.4em;
            color: #ccc; 
            margin: 0 0 40px 0;
            border-bottom: 1px solid #f0f0f0;
            padding-bottom: 12px;
        }
        
        .about-section p { 
            margin: 0; 
            font-size: 1.1rem;
            word-break: keep-all; 
            overflow-wrap: break-word;
            font-weight: 500;
        }

        .about-section p span {
            display: inline-block;
        }

        .spacer {
            display: block;
            height: 24px;
        }

        .about-section strong span {
            font-weight: 900;
            font-size: 1.8rem; /* 1.1remから、最もインパクトのあった1.8remへ復元 */
            margin-bottom: 24px;
            display: block;
            color: #000;
            letter-spacing: -0.01em;
        }

        /* Bridge Section (Nano-Minimalist with Copy) */
        .bridge-section {
            margin-top: 80px;
            padding: 120px 0;
            border-top: 1px solid #f0f0f0;
            text-align: left; /* ボックスではないため、左寄せで調和させる */
            max-width: 850px; /* 700pxから850pxへ拡張 */
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1), 
                        transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .bridge-section.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        .bridge-label {
            display: block;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.4em;
            text-transform: uppercase;
            color: #999;
            margin-bottom: 24px;
        }

        .bridge-title {
            font-size: 1.8rem;
            font-weight: 900;
            margin-bottom: 30px;
            letter-spacing: -0.02em;
            color: #000;
        }

        .bridge-desc {
            font-size: 1rem;
            color: #666;
            line-height: 1.8;
            margin: 0 0 60px;
        }

        .nano-bridge {
            display: inline-block;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            text-decoration: none;
            color: #ccc;
            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .nano-bridge:hover {
            color: #000;
            transform: translateX(5px); /* 右へ微動 */
        }

        @media (max-width: 768px) {
            .about-layout {
                padding: 60px 20px 80px;
                overflow-x: hidden; /* コンテンツのはみ出しによる揺れを防止 */
            }
            .about-section {
                margin-bottom: 80px;
            }
            .about-section p {
                font-size: 1rem;
                word-break: normal; /* 日本語の自然な改行を許可 */
            }
            .about-section p span {
                display: block; /* スマホでは各句を独立した行として扱い、意図しない箇所での断片化を防ぐ */
                max-width: 100%;
            }
            .about-section p br {
                display: none; /* spanのブロック化に伴う二重改行を防止 */
            }
            .about-section strong span {
                display: block;
                font-size: 1.4rem; /* 1.8remから縮小 */
                line-height: 1.4;
            }
            .phi-item {
                display: block;
                margin-bottom: 2.2em; /* スマホ版のみ項目間に一行分の空白を入れる */
            }
            .phi-item:last-child {
                margin-bottom: 0;
            }
            .bridge-section {
                padding: 60px 0;
                margin-top: 40px;
            }
            .bridge-title {
                font-size: 1.5rem;
            }
        }
    </style>

    <div class="about-layout">
        <h1 class="about-page-title">ABOUT</h1>
        <section class="about-section">
            <h2>Identity</h2>
            <p>
                <span>孝森 弘章 / Hiroaki Takamori</span>
                <span class="spacer"></span>
                <span>AI Creative Director /</span> <span>Brand Director</span>
            </p>
        </section>

        <section class="about-section">
            <h2>Method</h2>
            <p>
                <span>Logic & Intuition</span>
                <span class="spacer"></span>
                <span>Experience &</span> <span>AI Acceleration</span>
            </p>
        </section>

        <section class="about-section">
            <h2>History</h2>
            <p>
                <strong><span>30 Years of Insight.</span> <span>Synchronized with AI.</span></strong>
                <span>デザイン黎明期から</span><span>現在に至るまで、</span><br>
                <span>30年にわたり</span><span>ブランドの核心を射抜く</span><br>
                <span>ディレクションを</span><span>積み重ねてきました。</span>
                <span class="spacer"></span>
                <span>蓄積された審美眼と</span><span>AIの演算能力を</span><span>同期させ、</span><br>
                <span>時代に流されない</span><span>本質的な価値を</span><span>構築します。</span>
            </p>
        </section>

        <section class="about-section">
            <h2>Strategy</h2>
            <p>
                <strong><span>Minimalist Logic.</span> <span>Maximum Impact.</span></strong>
                <span>不要な要素を削ぎ落とし、</span><span>ブランドが持つ</span><br>
                <span>「真の記号（SYNCODE）」を</span><span>抽出すること。</span>
                <span class="spacer"></span>
                <span>熟練の直感による</span><span>「判断」と、</span><span>AIによる</span><br>
                <span>「具現化」を高度に同期させ、</span><span>ビジネスに</span><br>
                <span>静かな、しかし確かな熱量を</span><span>もたらします。</span>
            </p>
        </section>

        <section class="about-section">
            <h2>Editorial Policy</h2>
            <p>
                <strong><span>Technology & Thought. Both Sides.</span></strong>
                <span>SYNCODEが発信するすべての記事は、</span><span>AIの操作手順や技術だけでなく、</span><br>
                <span>それを「なぜやるのか」「どう使いこなすか」という</span><span>思想や戦略をセットで構成しています。</span>
                <span class="spacer"></span>
                <span>技術という盾と、思想という矛。</span><br>
                <span>この両方があって初めて、</span><span>AIはあなたの真の武器になります。</span>
            </p>
        </section>

        <section class="about-section">
            <h2>Philosophy: DTP &times; AI</h2>
            <p>
                <strong><span>DTPの職人性、AIの演算。その交差点。</span></strong>
                <span>30年の経験に裏打ちされた「DTPの定石」を、AIへのプロトコルへと変換します。</span>
                <span class="spacer"></span>
                <span class="phi-item"><span>1. <strong>言語化の深度</strong>: </span><span>専門用語による、</span><span>AIへの高解像度なディレクション。</span></span><br>
                <span class="phi-item"><span>2. <strong>審美眼の論理</strong>: </span><span>AI出力をプロの視点で評価し、</span><span>デザインとしての完成度へ。</span></span> <br>
                <span class="phi-item"><span>3. <strong>プロダクトの品質</strong>: </span><span>画面の中だけで完結しない、</span><span>印刷・制作に耐えうる実数値。</span></span><br>
                <span class="phi-item"><span>4. <strong>タイポグラフィの矜持</strong>: </span><span>AIが到達できない、</span><span>1/1000単位の「間」の設計。</span></span>
            </p>
        </section>

        <!-- BRIDGE TO WORKS (INTEGRATED VERSION) -->
        <div class="bridge-section">
            <span class="bridge-label">Identity in Action</span>
            <h2 class="bridge-title">実証：概念を形へ</h2>
            <p class="bridge-desc">
                思想を数式のように精緻に積み上げ、確かな実績へと変換する。<br/>
                SYNCODEが手がけたプロジェクトの実例をご覧ください。
            </p>
            <a href="/works/" class="nano-bridge">VIEW WORKS &rarr;</a>
        </div>
    </div>

    <!-- AI Search Optimization Section (GEO) -->
    <AISearchOptimizer type="about" />

    <script>
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };

            const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                }
            });
        }, observerOptions);

        const bridgeSection = document.querySelector('.bridge-section');
        if (bridgeSection) {
            observer.observe(bridgeSection);
        }
    </script>
</BaseLayout>