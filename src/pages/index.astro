---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PremiumDocumentary from "../components/PremiumDocumentary.astro";
import ArticleCard from "../components/ArticleCard.astro";

const allArticles = await getCollection("articles");
// Sort by date descending
const sortedArticles = allArticles.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Documentaryで使用しているIDを除去してLatestを作成
const documentaryIds = [
  'ga4-analysis-discovery',
  'ga4-sync-technical-guide',
  'ai-collaboration-ip-filter',
  'data-driven-seo-optimization'
];

// Essential Guidesの定義 (PDFのPOPULAR, GUIDE, ADVANCEDに対応)
const essentialConfig = [
  { id: 'seo-optimization-with-ai', label: 'POPULAR' },
  { id: 'antigravity-start', label: 'GUIDE' },
  { id: 'antigravity-browser-control-guide', label: 'ADVANCED' }
];

const essentialArticles = essentialConfig
    .map(config => {
      const article = allArticles.find(a => a.id === config.id);
      return article ? { ...article, topLabel: config.label } : null;
    })
    .filter(Boolean);

const latestArticles = sortedArticles
    .filter(article => !documentaryIds.includes(article.id) && !essentialConfig.some(c => c.id === article.id))
    .slice(0, 6);
---

<BaseLayout 
    title="SYNCODE | AI・Antigravityを使いこなすための実践技術ブログ"
    description="AIエージェントAntigravityと共に歩む、ブログ制作と収益化の記録。ディレクトリ構成の最適化からSEO、自動化技術まで、AI共創の最前線を技術ブログとして公開。"
>
    <!-- ヒーローセクション (PDF Page 1) -->
    <Hero />

    <!-- ドキュメンタリーセクション -->
    <PremiumDocumentary />

    <div class="content-sections">
        <!-- Essential Guides -->
        <section class="home-section essential">
            <div class="section-title-wrapper">
                <h2 class="section-title">Essential Guides</h2>
            </div>
            <div class="essential-grid">
                {essentialArticles.map(item => (
                    <ArticleCard article={item} variant="standard" topLabel={item.topLabel} />
                ))}
            </div>
        </section>

        <!-- Latest Articles -->
        <section class="home-section latest">
            <div class="section-title-wrapper">
                <h2 class="section-title">Latest Articles</h2>
                <a href="/articles/" class="view-all">EXPLORE ARCHIVE →</a>
            </div>
            <div class="latest-grid">
                {latestArticles.map(article => (
                    <ArticleCard article={article} variant="standard" />
                ))}
            </div>
            
            <div class="explore-archive-wrapper">
                <a href="/articles/" class="explore-btn">
                    <span class="btn-text">EXPLORE ALL RECORDS</span>
                    <span class="btn-arrow">→</span>
                </a>
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    .content-sections {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 5%;
    }

    .home-section {
        margin-bottom: 120px;
    }

    .section-title-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        padding-bottom: 15px;
        border-bottom: 2px solid #1a1a1a;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 900;
        letter-spacing: -0.02em;
        text-transform: uppercase;
    }

    .view-all {
        font-size: 0.75rem;
        font-weight: 800;
        color: #999;
        text-decoration: none;
        letter-spacing: 0.1em;
        transition: color 0.3s ease;
    }

    .view-all:hover {
        color: #000;
    }

    /* Essential Grid - 3 columns */
    .essential-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
    }

    /* Latest Grid - 3rd columns */
    .latest-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 60px 40px;
    }

    @media (max-width: 900px) {
        .essential-grid {
            grid-template-columns: 1fr;
        }
        .latest-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 600px) {
        .latest-grid {
            grid-template-columns: 1fr;
        }
    }

    .explore-archive-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 80px;
    }

    .explore-btn {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px 60px;
        background: #000;
        color: #fff;
        text-decoration: none;
        font-weight: 900;
        font-size: 1rem;
        letter-spacing: 0.1em;
        border-radius: 2px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .explore-btn:hover {
        background: #333;
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    }

    .btn-arrow {
        transition: transform 0.4s ease;
    }

    .explore-btn:hover .btn-arrow {
        transform: translateX(8px);
    }
</style>
