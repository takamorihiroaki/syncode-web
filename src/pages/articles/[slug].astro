---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tag from "../../components/Tag.astro";
import Category from "../../components/Category.astro";
import CtaTools from "../../components/CtaTools.astro";
import CtaWorks from "../../components/CtaWorks.astro";
import ArticleDiscovery from "../../components/ArticleDiscovery.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import CtaNextBanner from "../../components/CtaNextBanner.astro";
import FeaturedSeries from "../../components/FeaturedSeries.astro";

export async function getStaticPaths() {
    const articleEntries = await getCollection("articles");
    return articleEntries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// 次の記事（シリーズ内）を検索
const allArticles = await getCollection("articles");
const nextEntry = entry.data.series 
    ? allArticles.find(a => 
        a.data.series === entry.data.series && 
        a.data.seriesOrder === (entry.data.seriesOrder || 0) + 1
      )
    : null;

// シリーズ記事かどうかの判定
const isSeries = !!entry.data.series;

// インテリジェント導線の判定
let customNextEntry = null;

// シリーズが最終章（12）の場合、技術実例記事へ誘導する
if (isSeries && !nextEntry && entry.data.series === "AI Collaboration Story" && entry.data.seriesOrder === 12) {
    customNextEntry = allArticles.find(a => a.id === "seo-optimization-with-ai");
}

// 最終的な表示用Next
let displayNext = nextEntry || customNextEntry;

// 連載の次がない場合、関連記事のスコア1位をレコメンドとして採用する
if (!displayNext) {
    const recommendations = allArticles
        .filter(a => a.id !== entry.id && !a.data.draft)
        .map(a => {
            let score = 0;
            if (a.data.category === entry.data.category) score += 5;
            const commonTags = a.data.tags?.filter(t => (entry.data.tags || []).includes(t));
            score += (commonTags?.length || 0) * 2;
            return { article: a, score };
        })
        .sort((a, b) => b.score - a.score);

    if (recommendations.length > 0 && recommendations[0].score > 2) {
        displayNext = recommendations[0].article;
    }
}

// 導線コンポーネントの選定（バナーが出ない場合のフォールバック）
const tags = entry.data.tags || [];
const category = entry.data.category || "";

// 導線コンポーネントの選定
const worksKeywords = ["SEO", "Search Console", "成果", "デザイン", "Case Study", "実績", "ブランド設計", "構造改革", "UI-UX", "制作実績", "マーケティング"];
const toolsKeywords = ["Antigravity", "AIツール", "設定", "検証", "技術スタック", "トラブルシューティング", "初期設定", "パフォーマンス改善", "MCP", "Astro", "Gemini", "ワークスタイル", "自動化"];

const hasWorksTag = tags.some(tag => worksKeywords.includes(tag));
const hasToolsTag = tags.some(tag => toolsKeywords.includes(tag));

let footerCtaType = "tools"; // デフォルトをToolsに変更して一貫性を確保

if (category === "AI戦略" || category === "マーケティング" || hasWorksTag) {
    footerCtaType = "works";
} else {
    footerCtaType = "tools";
}

// Antigravity関連記事の場合、マスターガイドへの特別導線を有効化
const isAntigravityArticle = tags.includes("Antigravity") && entry.id !== "antigravity-master-guide";
---

<BaseLayout 
    title={entry.data.title} 
    description={entry.data.excerpt} 
    image={entry.data.image} 
    isArticle={true}
    publishDate={entry.data.date}
>

    <div class="article-header">
        {entry.data.category && <Category name={entry.data.category} />}
        <h1 class="article-title">{entry.data.title}</h1>
        <time class="article-date" datetime={entry.data.date.toISOString()}>
            {entry.data.date
                .toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit",
                })
                .replace(/\//g, ".")}
        </time>
    </div>

    <div class="ai-collaboration-badge" style="margin-bottom: 40px; display: flex; align-items: flex-start; gap: 12px; padding: 16px; background: #fdfdfd; border-left: 2px solid #000;">
        <div style="font-size: 1.1rem; line-height: 1;">🤖</div>
        <p style="font-size: 0.8rem; color: #666; line-height: 1.6; margin: 0; letter-spacing: 0.02em;">
            <strong>AI Collaboration Active:</strong> この記事は AI エージェント（Antigravity）が自律的にコンテキストを解析し、構成の提案から執筆までを人間と共同で行っています。データに基づいた客観性と、AI による次世代の制作プロセスを反映しています。
        </p>
    </div>

    {
        entry.data.image && (
            <div class="article-eyecatch">
                <img
                    src={entry.data.image}
                    alt={`${entry.data.title}のアイキャッチ画像 - SYNCODE`}
                />
            </div>
        )
    }

    <article class="article-content">
        <Content />

        <div class="nano-bridge">
          <span class="nano-line"></span>
          <a href="/works/" class="nano-link">実績：AIと共働した制作の記録へ →</a>
        </div>
        
        <!-- 動的導線（CTA）セクション -->
        <div class="article-cta-area" style="margin-top: 40px;">
            {/* ツール誘導は常に最優先で表示（回遊性と収益化の要） */}
            <CtaTools title={entry.data.ctaTitle} description={entry.data.ctaDesc} />

            {displayNext && (
                /* 次の記事がある場合は、ツールバナーの後に表示 */
                <div style="margin-top: 40px;">
                    <CtaNextBanner 
                        title={displayNext.data.title}
                        excerpt={displayNext.data.excerpt}
                        image={displayNext.data.image || ""}
                        link={`/articles/${displayNext.id}/`}
                        order={displayNext.data.seriesOrder}
                    />
                </div>
            )}
        </div>
        
        {isAntigravityArticle && (
            <div class="antigravity-hub-banner" style="margin: 60px 0; border: 1px solid #000; padding: 30px; border-radius: 8px; background: #fff;">
                <span style="font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: #999; display: block; margin-bottom: 12px;">Antigravity Resource Hub</span>
                <h3 style="font-size: 1.25rem; font-weight: 800; margin: 0 0 16px 0;">Antigravityを使いこなすための全ての知識をここに。</h3>
                <p style="font-size: 0.95rem; line-height: 1.6; color: #444; margin-bottom: 20px;">
                    導入、設定、パフォーマンス改善から高度な自動化まで。SYNCODEが公開している30以上のAntigravity関連記事を体系化した完全ガイドを公開しています。
                </p>
                <a href="/articles/antigravity-master-guide/" style="display: inline-block; padding: 12px 24px; background: #000; color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: bold; border-radius: 4px; transition: opacity 0.3s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                    マスターガイドを読む
                </a>
            </div>
        )}
        
        {entry.data.tags && entry.data.tags.length > 0 && (
            <div class="tag-list" style="margin-top: 60px; padding-top: 30px; border-top: 1px solid var(--color-border);">
                {entry.data.tags.map((tag) => <Tag name={tag} />)}
            </div>
        )}
    </article>

    { !isSeries && (
        /* 単発記事の場合はシリーズ特集枠を表示（記事本文の外に出して1100px幅を確保） */
        <FeaturedSeries />
    )}

    <RelatedPosts 
        currentId={entry.id} 
        tags={entry.data.tags} 
        category={entry.data.category} 
        series={entry.data.series}
        seriesOrder={entry.data.seriesOrder}
    />

</BaseLayout>

<style is:global>
  .nano-bridge {
    margin: 80px 0 20px;
    padding-top: 40px;
    position: relative;
    text-align: right;
  }
  .nano-line {
    position: absolute;
    top: 0;
    right: 0;
    width: 40px;
    height: 1px;
    background: #eee;
  }
  .nano-link {
    font-size: 0.75rem;
    color: #999;
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.3s ease;
  }
  .nano-link:hover {
    color: #333;
  }

  /* リンクリスト：線が走る演出 */
  .article-link-list {
    list-style: none !important;
    padding: 0 !important;
    margin: 40px 0 !important;
    color: #666;
    font-size: 0.95rem;
  }
  
  .article-link-list a {
    position: relative !important;
    color: #333 !important;
    text-decoration: none !important;
    display: inline !important;
    background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)) !important;
    background-position: 0 100% !important;
    background-repeat: no-repeat !important;
    background-size: 0 1px !important;
    transition: background-size 0.5s cubic-bezier(0.165, 0.84, 0.44, 1) !important;
    padding-bottom: 2px !important;
    box-decoration-break: clone !important;
    -webkit-box-decoration-break: clone !important;
  }
  
  .article-link-list a:hover {
    background-size: 100% 1px !important;
  }

  .article-link-item {
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .article-link-item .emoji {
    font-size: 1.1rem;
    opacity: 0.8;
  }
</style>
