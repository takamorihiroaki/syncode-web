---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tag from "../../components/Tag.astro";
import Category from "../../components/Category.astro";
import CtaTools from "../../components/CtaTools.astro";
import CtaWorks from "../../components/CtaWorks.astro";
import ArticleDiscovery from "../../components/ArticleDiscovery.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import CtaNextBanner from "../../components/CtaNextBanner.astro";
import FeaturedSeries from "../../components/FeaturedSeries.astro";
import SeriesList from "../../components/SeriesList.astro";
import RoadmapHub from "../../components/RoadmapHub.astro";
import CtaPlate from "../../components/CtaPlate.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import ReadingProgressBar from "../../components/ReadingProgressBar.astro";
import AISearchOptimizer from "../../components/AISearchOptimizer.astro";
import ArticleFeedback from "../../components/ArticleFeedback.astro";

// Antigravityのフェーズマッピング
const antigravityPhases: Record<string, string> = {
  "antigravity-start": "01",
  "antigravity-initial-setup-guide": "01",
  "antigravity-customization-setup-guide": "01",
  "mcp-basics-guide": "01",
  "antigravity-file-attachment-guide": "02",
  "antigravity-image-attachment-guide": "02",
  "antigravity-browser-control-guide": "02",
  "antigravity-file-ops-mastery": "02",
  "cursor-antigravity-workflow": "02",
  "antigravity-vs-cursor-vs-gemini-comparison": "02",
  "antigravity-not-working-fix": "03",
  "antigravity-performance-optimization-guide": "03",
  "antigravity-speed-optimization-prompt-cache": "03",
  "antigravity-code-not-working-guide": "03",
  "antigravity-performance-fix": "03",
  "mcp-server-custom-guide": "04",
  "mcp-autonomous-agent-workflow-2026": "04",
  "vibe-coding-practice-report": "04",
  "ai-fullstack-devops": "04"
};

export async function getStaticPaths() {
    const articleEntries = await getCollection("articles");
    return articleEntries.map((entry) => {
        // IDからディレクトリ部分を削除し、さらに拡張子（.md / .mdx）を除去してSlugを作成
        const slug = entry.id.split('/').pop()?.replace(/\.(md|mdx)$/, '') || entry.id;
        return {
            params: { slug },
            props: { entry },
        };
    });
}

const { entry } = Astro.props;
// IDからベース名を取得してフェーズ判定（ディレクトリが変わっても機能するように）
const entryBaseId = entry.id.split('/').pop()?.replace(/\.(md|mdx)$/, '') || entry.id;
const activePhase = antigravityPhases[entryBaseId];
const { Content, headings } = await render(entry);

// 次の記事（シリーズ内）を検索
const allArticles = await getCollection("articles");
const nextEntry = entry.data.series 
    ? allArticles.find(a => 
        a.data.series === entry.data.series && 
        a.data.seriesOrder === (entry.data.seriesOrder || 0) + 1
      )
    : null;

// シリーズ記事かどうかの判定
const isSeries = !!entry.data.series;

// インテリジェント導線の判定
let customNextEntry = null;

// シリーズが最終章（12）の場合、技術実例記事へ誘導する
if (isSeries && !nextEntry && entry.data.series === "AI Collaboration Story" && entry.data.seriesOrder === 12) {
    customNextEntry = allArticles.find(a => a.id === "seo-optimization-with-ai");
}

// 最終的な表示用Next
let displayNext = nextEntry || customNextEntry;

// 連載の次がない場合、関連記事のスコア1位をレコメンドとして採用する
if (!displayNext) {
    const recommendations = allArticles
        .filter(a => a.id !== entry.id && !a.data.draft)
        .map(a => {
            let score = 0;
            if (a.data.category === entry.data.category) score += 5;
            const commonTags = a.data.tags?.filter(t => (entry.data.tags || []).includes(t));
            score += (commonTags?.length || 0) * 2;
            return { article: a, score };
        })
        .sort((a, b) => b.score - a.score);

    if (recommendations.length > 0 && recommendations[0].score > 2) {
        displayNext = recommendations[0].article;
    }
}

// 導線コンポーネントの選定（バナーが出ない場合のフォールバック）
const tags = entry.data.tags || [];
const category = entry.data.category || "";

// 導線コンポーネントの選定
const worksKeywords = ["SEO", "Search Console", "成果", "デザイン", "Case Study", "実績", "ブランド設計", "構造改革", "UI-UX", "制作実績", "マーケティング"];
const toolsKeywords = ["Antigravity", "AIツール", "設定", "検証", "技術スタック", "トラブルシューティング", "初期設定", "パフォーマンス改善", "MCP", "Astro", "Gemini", "ワークスタイル", "自動化"];

const hasWorksTag = tags.some(tag => worksKeywords.includes(tag));
const hasToolsTag = tags.some(tag => toolsKeywords.includes(tag));

let footerCtaType = "tools"; // デフォルトをToolsに変更して一貫性を確保

if (category === "AI戦略" || category === "マーケティング" || hasWorksTag) {
    footerCtaType = "works";
} else {
    footerCtaType = "tools";
}

// Antigravity関連記事の場合、マスターガイドへの特別導線を有効化
const isAntigravityArticle = tags.includes("Antigravity") && entryBaseId !== "antigravity-master-guide";

// INSIGHT（サロン）カテゴリー判定
const isSalon = entry.data.category?.includes("INSIGHT");
---

<BaseLayout 
    title={entry.data.title} 
    description={entry.data.excerpt} 
    image={entry.data.image} 
    isArticle={true}
    publishDate={entry.data.date}
    bodyClass={isSalon ? "body-salon" : ""}
    faq={entry.data.faq}
    howTo={entry.data.howTo}
    category={entry.data.category}
>
    <ReadingProgressBar />

    <div class={isSalon ? "article-header article-header-salon" : "article-header"}>
        {entry.data.category && <Category name={entry.data.category} />}
        <h1 class="article-title">{entry.data.title}</h1>
        <time class="article-date" datetime={entry.data.date.toISOString()}>
            {entry.data.date
                .toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit",
                })
                .replace(/\//g, ".")}
        </time>
    </div>

    <div class="ai-collaboration-badge" style={`margin: 40px 0 60px; display: flex; align-items: flex-start; gap: 16px; padding: 24px; background: ${isSalon ? "rgba(255, 255, 255, 0.5)" : "rgba(253, 253, 253, 0.8)"}; border-left: 2px solid #000; backdrop-filter: blur(10px); border-radius: 0 4px 4px 0; box-shadow: 0 4px 20px rgba(0,0,0,0.02);`}>
        <div style="font-size: 1.2rem; line-height: 1; padding-top: 2px;">{isSalon ? "🖋️" : "🤖"}</div>
        <p style="font-size: 0.85rem; color: #555; line-height: 1.7; margin: 0; letter-spacing: 0.04em;">
            <strong style="color: #000; font-weight: 800; display: block; margin-bottom: 4px; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;">{isSalon ? "Thought Partnership Active" : "AI Collaboration Active"}</strong>
            {isSalon ? "この記事は、AI（Antigravity）との対話を通じて得られた洞察を、人間が「思考の記録」として編纂したものです。技術の表面的な解説を超え、AI共生時代の本質的な生存戦略を探求しています。" : "この記事は AI エージェント（Antigravity）が自律的にコンテキストを解析し、構成の提案から執筆までを人間と共同で行っています。データに基づいた客観性と、AI による次世代の制作プロセスを反映しています。"}
        </p>
    </div>

    {
        entry.data.image && (
            <div class={isSalon ? "article-eyecatch article-eyecatch-salon" : "article-eyecatch"}>
                <img
                    src={entry.data.image}
                    alt={`${entry.data.title}のアイキャッチ画像 - SYNCODE`}
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
        )
    }

    <article class={isSalon ? "article-content is-salon" : "article-content"}>
        <TableOfContents headings={headings} />
        <Content />
        
        {entry.data.faq && entry.data.faq.length > 0 && (
          <div class="article-faq-container" style="margin: 80px 0 40px; padding: 40px; background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: 2px;">
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 40px;">
              <span style="font-size: 0.7rem; letter-spacing: 0.3em; color: var(--color-text-light); font-weight: 900; text-transform: uppercase;">Questions & Answers</span>
            </div>
            <h2 style="margin-top: 0 !important; margin-bottom: 40px !important; text-align: left !important; font-size: 1.5rem !important; border-bottom: none !important;">よくある質問</h2>
            <dl class="faq-list">
              {entry.data.faq.map(item => (
                <div style="margin-bottom: 40px; border-bottom: 1px solid #eee; padding-bottom: 30px;">
                  <dt style="font-weight: 800; color: var(--color-text); margin-bottom: 15px; display: flex; gap: 15px; font-size: 1.1rem; line-height: 1.5;">
                    <span style="color: #333; opacity: 0.3;">Q.</span>
                    <span>{item.question}</span>
                  </dt>
                  <dd style="margin-left: 0; color: var(--color-text-light); line-height: 1.8; display: flex; gap: 15px; font-size: 0.95rem;">
                    <span style="font-weight: 800; color: #333; opacity: 0.3;">A.</span>
                    <span>{item.answer}</span>
                  </dd>
                </div>
              ))}
            </dl>
          </div>
        )}
        
        {isSeries && <SeriesList />}

        <ArticleFeedback title={entry.data.title} />

        <div class="nano-bridge">
          <span class="nano-line"></span>
          <a href="/works/" class="nano-link">実績：AIと共働した制作の記録へ →</a>
        </div>
        
        <!-- 動的導線（CTA）セクション -->
        <div class="article-cta-area" style="margin-top: 40px;">
            {/* ツール誘導は常に最優先で表示（回遊性と収益化の要） */}
            <CtaTools title={entry.data.ctaTitle} description={entry.data.ctaDesc} />

            {displayNext && (
                /* 次の記事がある場合は、ツールバナーの後に表示 */
                <CtaPlate 
                    title={displayNext.data.title}
                    excerpt={displayNext.data.excerpt}
                    image={displayNext.data.image || ""}
                    link={`/articles/${displayNext.id.split('/').pop()?.replace(/\.(md|mdx)$/, '')}/`}
                    label={nextEntry ? "NEXT STEP" : "RECOMMENDED"}
                    category={displayNext.data.category}
                />
            )}
        </div>
        
        {isAntigravityArticle && (
            <div class="antigravity-roadmap-section" style="margin: 80px 0 40px; padding-top: 60px; border-top: 2px solid #eee;">
                <div style="text-align: center; margin-bottom: 40px;">
                    <span style="font-size: 0.7rem; letter-spacing: 0.3em; color: #0099ff; font-weight: 900; text-transform: uppercase;">Progression Hub</span>
                    <h3 style="font-size: 1.5rem; font-weight: 900; margin: 10px 0;">Antigravity 習熟ロードマップ</h3>
                    <p style="font-size: 0.9rem; color: #666;">今の立ち位置を把握し、次のステップへ進みましょう。</p>
                </div>
                <RoadmapHub activePhase={activePhase} showHeader={false} />
                <div style="text-align: center; margin-top: 40px;">
                    <a href="/antigravity/hub/" style="font-size: 0.8rem; font-weight: 800; color: #333; text-decoration: none; border-bottom: 1px solid #000; padding-bottom: 4px;">完全攻略ハブの全体像を見る →</a>
                </div>
            </div>
        )}
        
        {entry.data.tags && entry.data.tags.length > 0 && (
            <div class="tag-list" style="margin-top: 60px; padding-top: 30px; border-top: 1px solid var(--color-border);">
                {entry.data.tags.map((tag) => <Tag name={tag} />)}
            </div>
        )}
    </article>

    { !isSeries && (
        /* 単発記事の場合はシリーズ特集枠を表示（記事本文の外に出して1100px幅を確保） */
        <FeaturedSeries />
    )}

    <RelatedPosts 
        currentId={entry.id} 
        tags={entry.data.tags} 
        category={entry.data.category} 
        series={entry.data.series}
        seriesOrder={entry.data.seriesOrder}
    />

    <AISearchOptimizer type="article" description={entry.data.excerpt} />
</BaseLayout>

<style is:global>
  /* INSIGHT (SALON) 全体デザイン */
  body.body-salon {
    background-color: #fcfcfc !important; /* 極めて柔らかいオフホワイト */
    color: #1a1a1a !important;
  }

  /* body.body-salon .site-header などのヘッダー用上書き設定を削除（通常メニューと共通化） */

  .is-salon {
    max-width: 720px !important;
    margin: 0 auto !important;
    font-size: 1.1rem !important;
    line-height: 2.2 !important;
    letter-spacing: 0.03em !important;
    color: #1a1a1a !important;
  }
  
  .is-salon h2 {
    font-size: 1.8rem !important;
    margin-top: 100px !important;
    margin-bottom: 40px !important;
    text-align: center !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em !important;
    position: relative !important;
    padding-bottom: 20px !important;
  }
  
  .is-salon h2::after {
    content: '' !important;
    position: absolute !important;
    bottom: 0 !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    width: 30px !important;
    height: 1px !important;
    background: #000 !important;
  }
  
  .is-salon h3 {
    font-size: 1.4rem !important;
    margin-top: 60px !important;
    margin-bottom: 24px !important;
    font-weight: 700 !important;
  }
  
  .article-header-salon {
    text-align: center !important;
    margin-bottom: 80px !important;
    padding-top: 40px !important;
  }
  
  .article-header-salon .article-title {
    font-size: 2.6rem !important;
    line-height: 1.3 !important;
    margin-top: 24px !important;
    margin-bottom: 24px !important;
    font-weight: 900 !important;
    letter-spacing: -0.02em !important;
  }
  
  .article-eyecatch-salon {
    margin-bottom: 100px !important;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05) !important;
    border-radius: 4px !important;
    overflow: hidden !important;
  }

  .is-salon blockquote {
    margin: 60px 0 !important;
    padding: 0 !important;
    border: none !important;
    text-align: center !important;
    font-style: italic !important;
    font-size: 1.25rem !important;
    color: #444 !important;
  }
  
  .is-salon hr {
    margin: 80px auto !important;
    width: 100px !important;
    border: none !important;
    border-top: 1px solid #eee !important;
  }

  /* 共通パーツ */
  .nano-bridge {
    margin: 80px 0 20px;
    padding-top: 40px;
    position: relative;
    text-align: right;
  }
  .nano-line {
    position: absolute;
    top: 0;
    right: 0;
    width: 40px;
    height: 1px;
    background: #eee;
  }
  .nano-link {
    font-size: 0.75rem;
    color: #999;
    text-decoration: none;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 700;
    transition: all 0.4s var(--ease-out-expo);
  }
  .nano-link:hover {
    color: #000;
    letter-spacing: 0.2em;
  }

  /* リンクリスト：線が走る演出 */
  .article-link-list {
    list-style: none !important;
    padding: 0 !important;
    margin: 40px 0 !important;
    color: #666;
    font-size: 0.95rem;
  }
  
  .article-link-list a {
    position: relative !important;
    color: #333 !important;
    text-decoration: none !important;
    display: inline !important;
    background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)) !important;
    background-position: 0 100% !important;
    background-repeat: no-repeat !important;
    background-size: 0 1px !important;
    transition: background-size 0.5s cubic-bezier(0.165, 0.84, 0.44, 1) !important;
    padding-bottom: 2px !important;
    box-decoration-break: clone !important;
    -webkit-box-decoration-break: clone !important;
  }
  
  .article-link-list a:hover {
    background-size: 100% 1px !important;
  }

  .article-link-item {
    margin-bottom: 24px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .article-link-item .emoji {
    font-size: 1.1rem;
    line-height: 1.7;
    opacity: 0.8;
    flex-shrink: 0;
  }
  .article-link-item .content {
    line-height: 1.7;
  }
</style>
