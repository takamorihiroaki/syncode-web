---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeaturedSeries from "../../components/FeaturedSeries.astro";
import ArticleCard from "../../components/ArticleCard.astro";

const allArticles = await getCollection("articles");
const sortedArticles = allArticles.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// 連続記事（シリーズ）の特定
const seriesGroups: Record<string, { name: string; articles: any[] }> = {};
allArticles.forEach(article => {
    if (article.data.series) {
        if (!seriesGroups[article.data.series]) {
            seriesGroups[article.data.series] = { name: article.data.series, articles: [] };
        }
        seriesGroups[article.data.series].articles.push(article);
    }
});

// 各シリーズ内でのソート
Object.values(seriesGroups).forEach(group => {
    group.articles.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));
});

// カテゴリーごとのグルーピング（シリーズ以外）
const categoryGroups: Record<string, any[]> = {};
allArticles.forEach(article => {
    if (!article.data.series) {
        const cat = article.data.category || "Uncategorized";
        if (!categoryGroups[cat]) categoryGroups[cat] = [];
        categoryGroups[cat].push(article);
    }
});

// システム開発履歴（Milestones）の定義
const systemLogs = [
    { title: "Library構造の定義と1カラム型アーカイブの完成", date: "2026.04.11", id: "4687c7fc", slug: "site-reform-ch1-showcase-library" },
    { title: "Heroセクションにおけるマーカーハイライト演出の実装", date: "2026.04.11", id: "948f3486", slug: "log-948f3486" },
    { title: "Gitバージョン管理体制の構築と安全性の確保", date: "2026.04.11", id: "8c983a58", slug: "log-8c983a58" },
    { title: "3D Blueprintアセットの復元とTrue Northへの回帰", date: "2026.04.11", id: "718e7c4a", slug: "log-718e7c4a" },
    { title: "連載第1章の執筆とドキュメンタリー性の強調", date: "2026.04.10", id: "cd776ec2", slug: "log-cd776ec2" },
    { title: "記事メタデータの標準化と全43記事の整合性修復", date: "2026.04.10", id: "bbacc58c", slug: "log-bbacc58c" },
    { title: "SVGベースのサムネイル管理システムの試作と検証", date: "2026.04.10", id: "6da351fc", slug: "log-6da351fc" },
    { title: "Astroコンテンツコレクションのスキーマ最適化", date: "2026.04.10", id: "daade84c", slug: "log-daade84c" },
    { title: "Zenn等の外部メディア・コンテンツの統合と回遊性強化", date: "2026.04.10", id: "07dc1449", slug: "log-07dc1449" },
    { title: "大規模MDXマイグレーションと画像パスの健全化", date: "2026.04.10", id: "45772e74", slug: "log-45772e74" },
    { title: "GA4データとの同期による実証的コンテンツ解析", date: "2026.04.09", id: "9b261e62", slug: "ga4-analysis-discovery" },
    { title: "検索コンソール同期とSEOインデックスの自動最適化", date: "2026.04.09", id: "620961b1", slug: "search-console-ai-sync-case-study" },
    { title: "人間とAIの共創ドキュメントの構造化", date: "2026.04.09", id: "5436195c", slug: "log-5436195c" },
    { title: "モバイル環境におけるヘッダーレイアウトのレスポンス修正", date: "2026.04.09", id: "815c7164", slug: "log-815c7164" },
    { title: "AIエージェントによる文脈に即したテキストの磨き上げ", date: "2026.04.09", id: "178074af", slug: "log-178074af" }
];
---

<BaseLayout title="Library - SYNCODE 技術と変革の全記録">
    <div class="archive-container">
        <div class="section-title-wrapper top-title">
            <h1 class="section-title">The Library</h1>
            <p class="section-subtitle">体系化された技術、思考、そして進化の全記録</p>
        </div>

        <FeaturedSeries />

        {/* 1. DOCUMENTATION PACKAGES */}
        <div class="archive-segment">
            <h2 class="segment-title">Documentation Packages</h2>
            {Object.values(seriesGroups).map(group => (
                <div class="series-package">
                    <div class="package-header">
                        <span class="package-count">全{group.articles.length}話</span>
                        <h3 class="package-title">{group.name}</h3>
                    </div>
                    <div class="package-grid">
                        {group.articles.map((article) => (
                             <ArticleCard article={article} variant="standard" />
                        ))}
                    </div>
                </div>
            ))}
        </div>

        {/* 2. SYSTEM CHRONICLES */}
        <div class="archive-segment">
            <h2 class="segment-title">SYSTEM CHRONICLES</h2>
            <div class="logs-container">
                {systemLogs.map(log => (
                    <a href={`/articles/${log.slug}/`} class="log-entry">
                        <div class="log-meta">
                            <span class="log-date">{log.date}</span>
                            <span class="log-id">#{log.id}</span>
                        </div>
                        <div class="log-content">
                            <h3 class="log-title">{log.title}</h3>
                        </div>
                    </a>
                ))}
            </div>
        </div>

        {/* 3. KNOWLEDGE BASE */}
        <div class="archive-segment">
            <h2 class="segment-title">KNOWLEDGE BASE</h2>
            <div class="category-grid">
                {Object.keys(categoryGroups).map(category => (
                    <div class="category-group">
                        <h3 class="category-group-name">
                            <span class="category-text">{category}</span>
                            <span class="category-line"></span>
                        </h3>
                        <div class="article-compact-list">
                            {categoryGroups[category].map(article => (
                                <a href={`/articles/${article.id}/`} class="compact-article">
                                    <div class="article-meta-area">
                                        <span class="article-date">
                                            {article.data.date.toLocaleDateString("ja-JP", {
                                                month: "2-digit",
                                                day: "2-digit",
                                            }).replace(/\//g, ".")}
                                        </span>
                                    </div>
                                    <span class="article-title">{article.data.title}</span>
                                </a>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .archive-container {
        padding: 80px 0;
    }

    .section-title-wrapper {
        margin-bottom: 80px;
        text-align: center;
    }

    .section-title {
        font-size: 3.8rem;
        font-weight: 900;
        letter-spacing: -0.03em;
        margin-bottom: 10px;
    }

    .section-subtitle {
        color: #888;
        font-size: 1.1rem;
    }

    .archive-segment {
        margin-bottom: 120px;
    }

    .segment-title {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.4em;
        color: #1a1a1a;
        margin-bottom: 60px;
        text-align: center;
    }

    /* シリーズパッケージ */
    .series-package {
        background: #fff;
        padding: 0;
        margin-bottom: 80px;
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
    }

    .package-header {
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 1px solid #f0f0f0;
    }

    .package-count {
        font-size: 0.75rem;
        color: #bbb;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .package-title {
        font-size: 1.6rem;
        font-weight: 800;
        margin-top: 5px;
    }

    .package-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 40px;
    }

    /* 
    ========================================
    1カラム・ミニマリズム・リスト (Chronicles & Knowledge)
    ========================================
    */
    .logs-container,
    .category-grid {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .log-entry,
    .compact-article {
        display: flex;
        align-items: flex-start;
        padding: 60px 0; /* 豊かな余白 */
        border-bottom: none; /* 境界線を廃止 */
        transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        text-decoration: none;
        color: inherit;
    }

    .log-entry:hover,
    .compact-article:hover {
        transform: translateX(20px);
    }

    /* メタデータ領域 (10.8pt / Tracking 80) */
    .log-meta,
    .article-meta-area {
        min-width: 140px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-right: 60px;
        padding-top: 15px; /* タイトルの重心に合わせる */
    }

    .log-date,
    .article-date,
    .log-id {
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        font-size: 14.4px; /* 10.8pt */
        color: #bbb;
        letter-spacing: 0.08em; /* Tracking 80 */
        font-weight: 400;
        text-transform: uppercase;
    }

    /* 極大タイトル (3.8rem / 900) */
    .log-title,
    .article-title {
        font-size: clamp(1.8rem, 5vw, 3.8rem);
        font-weight: 900;
        line-height: 1.1;
        color: #1a1a1a;
        letter-spacing: -0.04em;
        margin: 0;
        word-break: break-word;
    }

    /* KNOWLEDGE BASE 特定スタイル */
    .category-group {
        width: 100%;
        margin-bottom: 100px;
    }

    .category-group-name {
        margin-bottom: 40px;
        position: relative;
        display: inline-block;
        padding-bottom: 10px;
    }

    .category-text {
        font-size: 1.5rem;
        font-weight: 900;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #000;
    }

    .category-line {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 4px; /* 厚みのある4pxライン */
        background: #1a1a1a;
    }

    @media (max-width: 800px) {
        .log-entry,
        .compact-article {
            flex-direction: column;
            padding: 40px 0;
        }
        .log-meta,
        .article-meta-area {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
        color: #999;
        font-weight: 500;
    }

    .log-id {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.65rem;
        color: #ccc;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .log-title {
        font-size: clamp(1rem, 2.5vw, 1.3rem);
        font-weight: 700;
        line-height: 1.5;
        color: #1a1a1a;
        letter-spacing: -0.01em;
    }

    @media (max-width: 600px) {
        .log-entry {
            flex-direction: column;
            padding: 24px 10px;
        }
        .log-meta {
            margin-right: 0;
            margin-bottom: 12px;
            flex-direction: row;
            align-items: center;
            gap: 15px;
        }
    }
</style>
