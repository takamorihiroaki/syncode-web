---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeaturedSeries from "../../components/FeaturedSeries.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import TagCloud from "../../components/TagCloud.astro";
import SubPageHero from "../../components/SubPageHero.astro";

// 1. 全61記事を動的に取得
const allArticles = await getCollection("articles");
const sortedArticles = allArticles.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// 2. 3本柱（Packages / Chronicles / Knowledge Base）への振り分け
// PILLAR 1: Documentation Packages (連載単位)
const seriesGroups: Record<string, { name: string; articles: any[] }> = {};
allArticles.forEach(article => {
    if (article.data.series) {
        const seriesName = article.data.series;
        if (!seriesGroups[seriesName]) {
            seriesGroups[seriesName] = { name: seriesName, articles: [] };
        }
        seriesGroups[seriesName].articles.push(article);
    }
});
Object.values(seriesGroups).forEach(group => {
    group.articles.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));
});

// PILLAR 2: SYSTEM CHRONICLES (実録・ログの全リスト)
// 掟：連載の一部であっても、カテゴリーが「開発実録」や「System Log」ならここに表示する
const chronicles = allArticles
    .filter(a => 
        a.data.category === "開発実録" || 
        a.data.category === "System Log" || 
        a.data.category === "System Chronicles" ||
        a.id.startsWith("log-")
    )
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// PILLAR 3: KNOWLEDGE BASE (純粋なナレッジのみ)
// 掟：連載記事およびPillar 2に属する実録記事を除外
const knowledgeArticles = allArticles.filter(a => 
    !a.data.series && 
    a.data.category !== "開発実録" && 
    a.data.category !== "System Log" && 
    a.data.category !== "System Chronicles" &&
    !a.id.startsWith("log-")
);

const categoryGroups: Record<string, any[]> = {};
knowledgeArticles.forEach(article => {
    const cat = article.data.category || "Uncategorized";
    if (!categoryGroups[cat]) categoryGroups[cat] = [];
    categoryGroups[cat].push(article);
});

// カテゴリーの表示順序を定義 (掟に従い固定)
const categoryOrder = ["マーケティング", "AIツール", "AI戦略", "テクノロジー", "技術検証"];
const sortedCategories = Object.keys(categoryGroups).sort((a, b) => {
    const indexA = categoryOrder.indexOf(a);
    const indexB = categoryOrder.indexOf(b);
    if (indexA === -1) return 1;
    if (indexB === -1) return -1;
    return indexA - indexB;
});

// 各カテゴリー内の記事を日付順にソート
sortedCategories.forEach(cat => {
    categoryGroups[cat].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
});
---

<BaseLayout title="Library - SYNCODE 技術と変革の全記録">
    
    <SubPageHero 
        badge="Knowledge Ecosystem"
        title="The Library"
        description="体系化された技術、思考、そして進化の全記録。<br/>123件の記事から、あなたのビジネスを拡張する知を探索してください。"
        accent="gold"
    />

    <div class="archive-container">
        <FeaturedSeries />
        <TagCloud />

        {/* --- PILLAR 1: DOCUMENTATION PACKAGES --- */}
        <div class="archive-segment">
            <h2 class="segment-title">Documentation Packages</h2>
            {Object.values(seriesGroups).map(group => (
                <div class="series-package">
                    <div class="package-header">
                        <span class="package-count">全 {group.articles.length} 記事</span>
                        <h3 class="package-title">{group.name}</h3>
                    </div>
                    <div class="package-grid">
                        {group.articles.map((article) => (
                             <ArticleCard article={article} variant="standard" />
                        ))}
                    </div>
                </div>
            ))}
        </div>

        {/* --- PILLAR 2: SYSTEM CHRONICLES --- */}
        <div class="archive-segment">
            <h2 class="segment-title">System Chronicles</h2>
            <div class="logs-container">
                {chronicles.map(log => (
                    <a href={`/articles/${log.id}/`} class="log-entry">
                        <div class="log-meta">
                            <span class="log-date">
                                {log.data.date.toLocaleDateString("ja-JP", {
                                    month: "2-digit", day: "2-digit"
                                }).replace(/\//g, ".")}
                            </span>
                        </div>
                        <div class="log-content">
                            <h3 class="log-title">{log.data.title}</h3>
                        </div>
                    </a>
                ))}
            </div>
        </div>

        {/* --- PILLAR 3: KNOWLEDGE BASE --- */}
        <div class="archive-segment">
            <h2 class="segment-title">Knowledge Base</h2>
            {
                sortedCategories.map(category => (
                    <div class="category-group-section" key={category}>
                        <div class="category-header">
                            <h3 class="category-group-name">
                                <span class="category-text">{category}</span>
                                <span class="category-line"></span>
                            </h3>
                        </div>
                        <div class="article-compact-list">
                            {categoryGroups[category].sort((a,b) => b.data.date - a.data.date).map(article => (
                                <a href={`/articles/${article.id}/`} class="compact-article" key={article.id}>
                                    <div class="article-meta-area">
                                        <span class="article-date">
                                            {article.data.date.toLocaleDateString("ja-JP", {
                                                month: "2-digit", day: "2-digit"
                                            }).replace(/\//g, ".")}
                                        </span>
                                    </div>
                                    <h3 class="article-title">{article.data.title}</h3>
                                </a>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</BaseLayout>

<style>
    .archive-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 60px 20px 140px;
    }

    .archive-segment {
        margin-bottom: 160px;
    }

    .segment-title {
        font-family: var(--font-heading);
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.4em;
        color: #b8860b;
        margin-bottom: 60px;
        padding-bottom: 24px;
        border-bottom: 1px solid #f0f0f0;
    }

    /* Package Grid (Documentation) */
    .series-package {
        margin: 60px 0 120px 0;
        background: #fafafa;
        border: 1px solid #f0f0f0;
        padding: 120px 80px;
        position: relative;
    }
    @media (max-width: 900px) {
        .series-package {
            padding: 60px 24px;
            margin: 40px 0 80px 0;
        }
    }

    .package-header {
        margin-bottom: 80px;
    }

    .package-count {
        font-family: var(--font-heading);
        font-size: 0.7rem;
        color: #bbb;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 800;
    }

    .package-title {
        font-family: var(--font-heading);
        font-size: 2.2rem;
        font-weight: 800;
        margin-top: 10px;
        letter-spacing: -0.02em;
        color: #1a1a1a;
    }

    .package-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 80px 40px;
    }

    @media (max-width: 900px) {
        .package-grid {
            grid-template-columns: 1fr;
            gap: 40px;
        }
    }

    /* UNIFIED LIST DESIGN */
    .logs-container,
    .article-compact-list {
        display: flex;
        flex-direction: column;
    }

    .log-entry,
    .compact-article {
        display: flex;
        align-items: flex-start;
        padding: 32px 0;
        text-decoration: none;
        color: inherit;
        border-bottom: 1px solid #f0f0f0;
        transition: all 0.4s var(--ease-out-expo);
    }

    .log-entry:hover,
    .compact-article:hover {
        transform: translateX(15px);
        color: #000;
    }

    .log-meta,
    .article-meta-area {
        min-width: 120px;
        display: flex;
        flex-direction: column;
    }

    .log-date,
    .article-date {
        font-family: var(--font-heading);
        font-size: 0.75rem;
        color: #bbb;
        letter-spacing: 0.1em;
        font-weight: 800;
    }

    .log-title,
    .article-title {
        font-family: var(--font-heading);
        font-size: clamp(1.4rem, 4vw, 2.4rem);
        font-weight: 800;
        line-height: 1.2;
        color: #1a1a1a;
        letter-spacing: -0.02em;
        margin: 0;
        transition: color 0.3s ease;
        word-break: break-word;
    }

    /* KNOWLEDGE BASE */
    .category-group-section {
        margin-bottom: 120px;
    }

    .category-header {
        margin-bottom: 40px;
    }

    .category-group-name {
        position: relative;
        display: block;
        padding-bottom: 14px;
        margin-top: 60px;
    }

    .category-text {
        font-family: var(--font-heading);
        font-size: 1.2rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #000;
    }

    .category-line {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: #000;
    }

    @media (max-width: 768px) {
        .log-entry,
        .compact-article {
            flex-direction: column;
            padding: 32px 0;
        }
        .log-meta,
        .article-meta-area {
            margin-bottom: 12px;
        }
    }
</style>
