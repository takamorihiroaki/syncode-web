---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeaturedSeries from "../../components/FeaturedSeries.astro";
import ArticleCard from "../../components/ArticleCard.astro";

// 1. 全61記事を動的に取得
const allArticles = await getCollection("articles");
const sortedArticles = allArticles.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// 2. 3本柱（Packages / Chronicles / Knowledge Base）への振り分け
// PILLAR 1: Documentation Packages
const seriesGroups: Record<string, { name: string; articles: any[] }> = {};
allArticles.forEach(article => {
    if (article.data.series) {
        const seriesName = article.data.series;
        if (!seriesGroups[seriesName]) {
            seriesGroups[seriesName] = { name: seriesName, articles: [] };
        }
        seriesGroups[seriesName].articles.push(article);
    }
});
Object.values(seriesGroups).forEach(group => {
    group.articles.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));
});

// PILLAR 2: SYSTEM CHRONICLES
const chronicles = allArticles
    .filter(a => a.data.category === "開発実録" || a.id.startsWith("log-"))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// PILLAR 3: KNOWLEDGE BASE
const knowledgeArticles = allArticles.filter(a => 
    !a.data.series && 
    a.data.category !== "開発実録" && 
    !a.id.startsWith("log-")
);

const categoryGroups: Record<string, any[]> = {};
knowledgeArticles.forEach(article => {
    const cat = article.data.category || "Uncategorized";
    if (!categoryGroups[cat]) categoryGroups[cat] = [];
    categoryGroups[cat].push(article);
});

// カテゴリーの表示順序を定義
const categoryOrder = ["マーケティング", "AIツール", "AI戦略", "テクノロジー", "技術検証"];
const sortedCategories = Object.keys(categoryGroups).sort((a, b) => {
    const indexA = categoryOrder.indexOf(a);
    const indexB = categoryOrder.indexOf(b);
    if (indexA === -1) return 1;
    if (indexB === -1) return -1;
    return indexA - indexB;
});
---

<BaseLayout title="Library - SYNCODE 技術と変革の全記録">
    <div class="archive-container">
        <div class="section-title-wrapper top-title">
            <h1 class="section-title">The Library</h1>
            <p class="section-subtitle">体系化された技術、思考、そして進化の全記録</p>
        </div>

        <FeaturedSeries />

        {/* --- PILLAR 1: DOCUMENTATION PACKAGES --- */}
        <div class="archive-segment">
            <h2 class="segment-title">DOCUMENTATION PACKAGES</h2>
            {Object.values(seriesGroups).map(group => (
                <div class="series-package">
                    <div class="package-header">
                        <span class="package-count">全 {group.articles.length} 記事</span>
                        <h3 class="package-title">{group.name}</h3>
                    </div>
                    <div class="package-grid">
                        {group.articles.map((article) => (
                             <ArticleCard article={article} variant="standard" />
                        ))}
                    </div>
                </div>
            ))}
        </div>

        {/* --- PILLAR 2: SYSTEM CHRONICLES (日付のみの純化) --- */}
        <div class="archive-segment">
            <h2 class="segment-title">SYSTEM CHRONICLES</h2>
            <div class="logs-container">
                {chronicles.map(log => (
                    <a href={`/articles/${log.id}/`} class="log-entry">
                        <div class="log-meta">
                            <span class="log-date">
                                {log.data.date.toLocaleDateString("ja-JP", {
                                    year: "numeric", month: "2-digit", day: "2-digit"
                                }).replace(/\//g, ".")}
                            </span>
                        </div>
                        <div class="log-content">
                            <h3 class="log-title">{log.data.title}</h3>
                        </div>
                    </a>
                ))}
            </div>
        </div>

        {/* --- PILLAR 3: KNOWLEDGE BASE (1-Column List by Category) --- */}
        <div class="archive-segment">
            <h2 class="segment-title">KNOWLEDGE BASE</h2>
            {
                sortedCategories.map(category => (
                    <div class="category-group-section" key={category}>
                        <div class="category-header">
                            <h3 class="category-group-name">
                                <span class="category-text">{category}</span>
                                <span class="category-line"></span>
                            </h3>
                        </div>
                        <div class="article-compact-list">
                            {categoryGroups[category].sort((a,b) => b.data.date - a.data.date).map(article => (
                                <a href={`/articles/${article.id}/`} class="compact-article" key={article.id}>
                                    <div class="article-meta-area">
                                        <span class="article-date">
                                            {article.data.date.toLocaleDateString("ja-JP", {
                                                year: "numeric", month: "2-digit", day: "2-digit"
                                            }).replace(/\//g, ".")}
                                        </span>
                                    </div>
                                    <h3 class="article-title">{article.data.title}</h3>
                                </a>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</BaseLayout>

<style>
    .archive-container {
        padding: 100px 0;
    }

    .section-title-wrapper {
        margin-bottom: 120px;
        text-align: center;
    }

    .section-title {
        font-size: 3.8rem;
        font-weight: 900;
        letter-spacing: -0.04em;
        margin-bottom: 20px;
        color: #000;
    }

    .section-subtitle {
        color: #888;
        font-size: 14.4px; /* 10.8pt */
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .archive-segment {
        margin-bottom: 180px;
        max-width: 1200px; /* 全体のベースを一律に */
        margin-left: auto;
        margin-right: auto;
        padding: 0 40px;
    }

    .segment-title {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.6em;
        color: #1a1a1a;
        margin-bottom: 80px;
        text-align: center;
        opacity: 0.6;
    }

    /* Package Grid (Documentation) */
    .series-package {
        margin-bottom: 120px;
    }

    .package-header {
        margin-bottom: 60px;
    }

    .package-count {
        font-family: 'Helvetica Neue', Arial, sans-serif;
        font-size: 14.4px; /* 10.8pt */
        color: #bbb;
        letter-spacing: 0.08em; /* Tracking 80 */
        text-transform: uppercase;
    }

    .package-title {
        font-size: 2.2rem;
        font-weight: 900;
        margin-top: 10px;
        letter-spacing: -0.02em;
    }

    .package-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 60px 40px;
    }

    /* 
    ========================================
    UNIFIED LIST DESIGN (Chronicles & Knowledge)
    ========================================
    */
    .logs-container,
    .article-compact-list {
        display: flex;
        flex-direction: column;
    }

    .log-entry,
    .compact-article {
        display: flex;
        align-items: flex-start;
        padding: 80px 0; /* 掟：80pxの余白 */
        text-decoration: none;
        color: inherit;
        border-bottom: none; /* 境界線を完全排除 */
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .log-entry:hover,
    .compact-article:hover {
        transform: translateX(30px);
    }

    /* 
     * 掟：10.8pt / Tracking 80 の日付のみ
     */
    .log-meta,
    .article-meta-area {
        min-width: 140px; /* 日付のみに合わせて最適化 */
        display: flex;
        flex-direction: column;
        padding-top: 1.25rem; /* タイトルの重心に一直線に揃える */
    }

    .log-date,
    .article-date {
        font-family: 'Helvetica Neue', Arial, sans-serif;
        font-size: 14.4px; /* 10.8pt */
        color: #bbb;
        letter-spacing: 0.08em; /* Tracking 80 */
        text-transform: uppercase;
        font-weight: 400;
    }

    /* 
     * 掟：タイトルの極大化 (3.8rem / 900)
     */
    .log-title,
    .article-title {
        font-size: clamp(1.8rem, 8vw, 3.8rem);
        font-weight: 900;
        line-height: 1.05;
        color: #1a1a1a;
        letter-spacing: -0.05em;
        margin: 0;
        word-break: break-word;
    }

    /* --- KNOWLEDGE BASE Specific --- */
    .category-group-section {
        margin-bottom: 120px;
    }

    .category-header {
        margin-bottom: 20px;
    }

    .category-group-name {
        position: relative;
        display: inline-block;
        padding-bottom: 12px;
    }

    .category-text {
        font-size: 1.1rem;
        font-weight: 900;
        letter-spacing: 0.5em;
        text-transform: uppercase;
        color: #000;
        padding-left: 0.5em;
    }

    .category-line {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 4px; /* 掟：厚みのある4pxライン */
        background: #000;
    }

    @media (max-width: 900px) {
        .log-entry,
        .compact-article {
            flex-direction: column;
            padding: 50px 0;
        }
        .log-meta,
        .article-meta-area {
            min-width: auto;
            margin-bottom: 20px;
            padding-top: 0;
        }
        .archive-segment {
            padding: 0 24px;
        }
    }
</style>
